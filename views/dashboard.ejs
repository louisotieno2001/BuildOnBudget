<!DOCTYPE html>
<html lang="en" class="scroll-smooth dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard - BuildOnBudget</title>
  <link href="/output.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Oswald:wght@200..700&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
  <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script defer src="/javascript/index.js"></script>
  <script src="/javascript/toast.js"></script>
  <script defer src="/javascript/dashboard.js"></script>
  <style>
    :root {
      --font-heading: 'Oswald', sans-serif;
      --font-body: 'Plus Jakarta Sans', sans-serif;
      --font-accent: 'DM Sans', sans-serif;
    }
    body {
      font-family: var(--font-body);
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .font-accent {
      font-family: var(--font-accent);
    }
    .hero-gradient {
      background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #312e81 100%);
    }
    .hero-pattern {
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .float-animation {
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-20px); }
    }
    .glow-effect {
      box-shadow: 0 0 60px rgba(139, 92, 246, 0.3);
    }
    .btn-glow:hover {
      box-shadow: 0 0 30px rgba(139, 92, 246, 0.5);
    }
    /* Custom Sidebar styles */
    .sidebar-link-active {
      @apply bg-purple-600/20 text-purple-400 border-r-4 border-purple-500;
    }
    .tab-button:hover {
      @apply bg-white/5;
    }
    .card-modern {
      @apply bg-slate-800/50 backdrop-blur-md border border-slate-700/50 rounded-2xl transition-all duration-300;
    }
    .card-modern:hover {
      @apply border-purple-500/30 shadow-lg shadow-purple-500/10 -translate-y-1;
    }
  </style>
</head>

<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col">

  <!-- HEADER -->
  <header class="bg-slate-900/80 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
    <div class="flex justify-between items-center px-4 py-3 md:px-8 max-w-[1600px] mx-auto">
      <!-- Left: Menu + Brand -->
      <div class="flex items-center space-x-4">
        <button id="sidebar-toggle" class="md:hidden text-slate-300 hover:text-white transition">
          <i class="fas fa-bars text-xl"></i>
        </button>
        <div class="flex items-center space-x-3">
          <img src="/images/logo.png" alt="Logo" class="w-10 h-10">
          <span class="text-xl font-bold text-white tracking-wide hidden sm:block">BUILDON<span class="text-purple-400">BUDGET</span></span>
        </div>
      </div>
      <!-- Right: Actions -->
      <div class="flex items-center space-x-6">
        <a href="/new-project" class="hidden sm:inline-flex items-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-semibold text-sm transition btn-glow">
          <i class="fas fa-plus"></i>
          <span>New Project</span>
        </a>
        <div class="relative group">
          <button id="profile-toggle" class="flex items-center space-x-3 focus:outline-none">
            <div class="relative">
              <img src="<%= normalizeMediaUrl(user.profile_image) || 'https://picsum.photos/200/300/?blur=2' %>"
                   class="w-10 h-10 rounded-full border-2 border-purple-500/50 object-cover">
              <div class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-slate-900 rounded-full"></div>
            </div>
            <i class="fas fa-chevron-down text-xs text-slate-400 group-hover:text-white transition"></i>
          </button>
          <!-- Profile Dropdown -->
          <div id="profile-dropdown" class="absolute right-0 mt-3 w-56 bg-slate-800 border border-slate-700 rounded-xl shadow-2xl py-2 hidden overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-700 mb-1">
              <p class="text-sm font-semibold text-white"><%= user.name %></p>
              <p class="text-xs text-slate-400 truncate"><%= user.email %></p>
            </div>
            <a href="/" class="flex items-center px-4 py-2 text-sm text-slate-300 hover:bg-purple-600 hover:text-white transition">
              <i class="fas fa-house-chimney w-5 text-center mr-3"></i> Home
            </a>
            <a href="#settings" class="flex items-center px-4 py-2 text-sm text-slate-300 hover:bg-purple-600 hover:text-white transition tab-trigger" data-target="settings">
              <i class="fas fa-user-gear w-5 text-center mr-3"></i> Profile Settings
            </a>
            <a href="#notifications" class="flex items-center px-4 py-2 text-sm text-slate-300 hover:bg-purple-600 hover:text-white transition tab-trigger" data-target="notifications">
              <i class="fas fa-bell w-5 text-center mr-3"></i> Notifications
            </a>
            <div class="border-t border-slate-700 mt-1">
              <a href="/logout" class="flex items-center px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 transition">
                <i class="fas fa-right-from-bracket w-5 text-center mr-3"></i> Logout
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="flex flex-1">

    <!-- MOBILE OVERLAY -->
    <div id="mobile-overlay" class="fixed inset-0 bg-black/50 md:hidden z-40 hidden"></div>

    <!-- SIDEBAR -->
    <aside id="sidebar"
      class="fixed md:static inset-y-0 left-0 w-72 bg-slate-900 border-r border-slate-800 z-50 transform transition-all duration-300 -translate-x-full md:translate-x-0 overflow-y-auto">
        
      <div class="flex flex-col h-full py-6">
       <!-- Sidebar User Info -->
        <div class="px-6 mb-8 flex items-center space-x-4">
          <div class="relative">
            <img src="<%= normalizeMediaUrl(user.profile_image) || 'https://picsum.photos/200/300/?blur=2' %>" 
                 class="w-12 h-12 rounded-full border-2 border-purple-500/50 object-cover shadow-lg shadow-purple-500/20">
          </div>
          <div class="overflow-hidden">
            <p class="font-bold text-white truncate"><%= user.name %></p>
            <p class="text-xs text-slate-400 truncate"><%= user.email %></p>
          </div>
        </div>

        <!-- Navigation Menu -->
        <nav class="flex-1 px-4">
          <ul class="space-y-1">
            <li>
              <button data-tab="dashboard" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group sidebar-link-active">
                <i class="fas fa-chart-line w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                <span class="font-medium">Overview</span>
              </button>
            </li>
            <li>
              <button data-tab="projects" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:text-white hover:bg-slate-800">
                <i class="fas fa-folder-tree w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                <span class="font-medium">Projects</span>
              </button>
            </li>
            <li>
              <button data-tab="tasks" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:text-white hover:bg-slate-800">
                <i class="fas fa-list-check w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                <span class="font-medium">Tasks</span>
              </button>
            </li>
            <li>
              <button data-tab="budget" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:text-white hover:bg-slate-800">
                <i class="fas fa-wallet w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                <span class="font-medium">Budget Control</span>
              </button>
            </li>
            <li>
              <button data-tab="teams" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:text-white hover:bg-slate-800">
                <i class="fas fa-users-viewfinder w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                <span class="font-medium">Teams</span>
              </button>
            </li>
            <li>
              <button data-tab="shop" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:text-white hover:bg-slate-800">
                <i class="fas fa-cart-flatbed w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                <span class="font-medium">Shop Materials</span>
              </button>
            </li>
            <div class="pt-6 mt-6 border-t border-slate-800">
              <li>
                <button data-tab="settings" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:text-white hover:bg-slate-800">
                  <i class="fas fa-sliders w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                  <span class="font-medium">Settings</span>
                </button>
              </li>
              <li>
                <button data-tab="notifications" class="tab-button w-full flex items-center px-4 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:text-white hover:bg-slate-800 relative">
                  <i class="fas fa-bell w-6 text-center mr-3 text-lg transition group-hover:scale-110"></i>
                  <span class="font-medium">Notifications</span>
                  <% if (pendingNotifications > 0) { %>
                    <span class="absolute right-4 top-1/2 -translate-y-1/2 flex h-5 w-5 items-center justify-center rounded-full bg-purple-600 text-[10px] font-bold text-white"><%= pendingNotifications %></span>
                  <% } %>
                </button>
              </li>
            </div>
          </ul>
        </nav>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 p-4 md:p-8 space-y-8 overflow-y-auto">

      <!-- Dashboard Tab -->
      <div id="tab-dashboard" class="tab-content space-y-8">
        <!-- Welcome Hero -->
        <div class="relative overflow-hidden rounded-3xl hero-gradient p-8 md:p-12 shadow-2xl">
          <div class="relative z-10">
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
              👋 Welcome back, <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-200 to-pink-200"><%= user.name %>!</span>
            </h2>
            <p class="text-purple-100 text-lg max-w-2xl">
              You're making great progress. Here's what's happening with your construction projects today.
            </p>
          </div>
          <!-- Decorative element -->
          <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
        </div>

        <!-- Quick Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="card-modern p-6 group">
            <div class="flex items-center justify-between mb-4">
              <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400 group-hover:scale-110 transition">
                <i class="fas fa-layer-group text-xl"></i>
              </div>
              <span class="text-xs font-bold text-blue-400 uppercase tracking-wider">Active</span>
            </div>
            <p class="text-slate-400 text-sm font-medium mb-1">Total Projects</p>
            <h3 class="text-3xl font-bold text-white"><%= activeProjects %></h3>
          </div>

          <div class="card-modern p-6 group">
            <div class="flex items-center justify-between mb-4">
              <div class="w-12 h-12 bg-amber-500/20 rounded-xl flex items-center justify-center text-amber-400 group-hover:scale-110 transition">
                <i class="fas fa-clock-rotate-left text-xl"></i>
              </div>
              <span class="text-xs font-bold text-amber-400 uppercase tracking-wider">Urgent</span>
            </div>
            <p class="text-slate-400 text-sm font-medium mb-1">Tasks Due</p>
            <h3 class="text-3xl font-bold text-white"><%= tasksDue %></h3>
          </div>

          <div class="card-modern p-6 group">
            <div class="flex items-center justify-between mb-4">
              <div class="w-12 h-12 bg-emerald-500/20 rounded-xl flex items-center justify-center text-emerald-400 group-hover:scale-110 transition">
                <i class="fas fa-money-bill-trend-up text-xl"></i>
              </div>
              <span class="text-xs font-bold text-emerald-400 uppercase tracking-wider">Budget</span>
            </div>
            <p class="text-slate-400 text-sm font-medium mb-1">Spent (KES)</p>
            <h3 class="text-3xl font-bold text-white"><%= budgetSpent.toLocaleString() %></h3>
          </div>

          <div class="card-modern p-6 group">
            <div class="flex items-center justify-between mb-4">
              <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center text-purple-400 group-hover:scale-110 transition">
                <i class="fas fa-users-gear text-xl"></i>
              </div>
              <span class="text-xs font-bold text-purple-400 uppercase tracking-wider">Network</span>
            </div>
            <p class="text-slate-400 text-sm font-medium mb-1">Team Size</p>
            <h3 class="text-3xl font-bold text-white"><%= teamMembers %></h3>
          </div>
        </div>

        <!-- Charts and Analysis -->
        <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8">
          <!-- Task Status Chart -->
          <div class="card-modern p-6">
            <div class="flex items-center justify-between mb-6">
              <h4 class="text-lg font-bold text-white tracking-wide">Task Distribution</h4>
              <i class="fas fa-chart-pie text-slate-500"></i>
            </div>
            <div class="relative">
              <canvas id="taskStatusChart" class="max-h-[250px]" data-pending="<%= taskStatusCounts.pending %>" data-in-progress="<%= taskStatusCounts.in_progress %>" data-completed="<%= taskStatusCounts.completed %>"></canvas>
            </div>
          </div>

          <!-- Monthly Performance -->
          <div class="card-modern p-6">
            <div class="flex items-center justify-between mb-6">
              <h4 class="text-lg font-bold text-white tracking-wide">Monthly Velocity</h4>
              <i class="fas fa-chart-line text-slate-500"></i>
            </div>
            <div class="relative">
              <canvas id="monthlyTasksChart" class="max-h-[250px]" data-labels="<%= JSON.stringify(monthlyTasksLabels) %>" data-data="<%= JSON.stringify(monthlyTasksData) %>"></canvas>
            </div>
          </div>

          <!-- Project Progress List -->
          <div class="card-modern p-6 lg:col-span-2 xl:col-span-1">
            <div class="flex items-center justify-between mb-6">
              <h4 class="text-lg font-bold text-white tracking-wide">Project Milestones</h4>
              <i class="fas fa-list-ul text-slate-500"></i>
            </div>
            <div class="space-y-6">
              <% const allProjectsForProgress = [...(projects || []).map(p => ({ project: p, role: null })), ...(invitedProjects || [])]; %>
              <% if (allProjectsForProgress.length > 0) { %>
                <% allProjectsForProgress.slice(0, 4).forEach(item => { %>
                  <% const project = item.project; %>
                  <% const completed = project.tasks.filter(t => t.status === 'completed').length; %>
                  <% const total = project.tasks.length; %>
                  <% const progress = total > 0 ? Math.round((completed / total) * 100) : 0; %>
                  <div>
                    <div class="flex justify-between items-center mb-2">
                      <span class="text-sm font-semibold text-slate-300 truncate pr-4"><%= project.name %></span>
                      <span class="text-xs font-bold text-purple-400 bg-purple-500/10 px-2 py-0.5 rounded"><%= progress %>%</span>
                    </div>
                    <div class="w-full bg-slate-700/50 rounded-full h-2 overflow-hidden">
                      <div class="bg-gradient-to-r from-purple-500 to-pink-500 h-full rounded-full transition-all duration-1000" style="width: <%= progress %>%;"></div>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="text-center py-8">
                  <i class="fas fa-folder-open text-4xl text-slate-700 mb-3"></i>
                  <p class="text-slate-500 text-sm">No active projects to track.</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Projects Tab -->
      <div id="tab-projects" class="tab-content space-y-6 hidden">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
          <div>
            <h3 class="text-2xl font-bold text-white tracking-wide">📁 My Projects</h3>
            <p class="text-slate-400 text-sm">Manage and monitor all your construction ventures.</p>
          </div>
          <a href="/new-project" class="inline-flex items-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-6 py-2.5 rounded-xl font-bold text-sm transition btn-glow">
            <i class="fas fa-plus-circle"></i>
            <span>New Project</span>
          </a>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% const allProjects = [...(projects || []).map(p => ({ project: p, role: null })), ...(invitedProjects || [])]; %>
          <% if (allProjects && allProjects.length > 0) { %>
            <% allProjects.forEach(item => { %>
              <% const { project, role } = item; %>
              <div class="card-modern p-6 flex flex-col group relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4">
                  <% if (role) { %>
                    <span class="text-[10px] font-black uppercase tracking-tighter bg-blue-500/20 text-blue-400 px-2 py-1 rounded border border-blue-500/20">Invited: <%= role %></span>
                  <% } else { %>
                    <span class="text-[10px] font-black uppercase tracking-tighter bg-purple-500/20 text-purple-400 px-2 py-1 rounded border border-purple-500/20">Owner</span>
                  <% } %>
                </div>
                
                <div class="mb-4 pt-2">
                  <h4 class="text-xl font-bold text-white group-hover:text-purple-400 transition-colors mb-2"><%= project.name %></h4>
                  <p class="text-slate-400 text-sm line-clamp-2 leading-relaxed mb-4"><%= project.description %></p>
                </div>
                
                <div class="mt-auto space-y-4">
                  <div class="flex items-center justify-between text-sm">
                    <div class="flex items-center text-slate-400">
                      <i class="fas fa-wallet mr-2 text-xs text-purple-500"></i>
                      <span>KES <%= project.budget.toLocaleString() %></span>
                    </div>
                    <% const taskCount = project.tasks ? project.tasks.length : 0; %>
                    <div class="flex items-center text-slate-400">
                      <i class="fas fa-tasks mr-2 text-xs text-purple-500"></i>
                      <span><%= taskCount %> Tasks</span>
                    </div>
                  </div>
                  
                  <a href="/dashboard/<%= project.id %>" class="w-full inline-flex items-center justify-center space-x-2 bg-slate-700/50 hover:bg-purple-600 text-white py-2.5 rounded-xl text-sm font-bold transition-all group/btn">
                    <span>Manage Project</span>
                    <i class="fas fa-arrow-right text-xs group-hover/btn:translate-x-1 transition-transform"></i>
                  </a>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="col-span-full py-20 text-center card-modern">
              <div class="w-20 h-20 bg-slate-700/30 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fas fa-folder-plus text-3xl text-slate-500"></i>
              </div>
              <h4 class="text-xl font-bold text-white mb-2">No projects yet</h4>
              <p class="text-slate-400 mb-8 max-w-sm mx-auto">Start your first construction project today and keep everything under control.</p>
              <a href="/new-project" class="inline-flex items-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-8 py-3 rounded-xl font-bold transition btn-glow">
                <i class="fas fa-plus"></i>
                <span>Create First Project</span>
              </a>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Tasks Tab -->
      <div id="tab-tasks" class="tab-content space-y-6 hidden">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
          <div>
            <h3 class="text-2xl font-bold text-white tracking-wide">📝 Active Tasks</h3>
            <p class="text-slate-400 text-sm">Stay on top of your project deadlines and requirements.</p>
          </div>
          <a href="/new-task" class="inline-flex items-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-6 py-2.5 rounded-xl font-bold text-sm transition btn-glow">
            <i class="fas fa-plus-circle"></i>
            <span>Add New Task</span>
          </a>
        </div>

        <div class="space-y-6">
          <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
              <div class="card-modern overflow-hidden">
                <div class="flex justify-between items-center px-6 py-4 bg-slate-700/30 cursor-pointer project-toggle group" data-project="<%= project.id %>">
                  <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-purple-500/20 rounded-lg flex items-center justify-center text-purple-400">
                      <i class="fas fa-folder"></i>
                    </div>
                    <h4 class="text-lg font-bold text-white group-hover:text-purple-400 transition"><%= project.name %></h4>
                    <span class="text-xs bg-slate-700 text-slate-400 px-2 py-0.5 rounded-full"><%= project.tasks.length %> tasks</span>
                  </div>
                  <i class="fas fa-chevron-down text-slate-500 transition-transform duration-300 project-indicator"></i>
                </div>
                
                <div class="project-tasks hidden divide-y divide-slate-700/50" data-project="<%= project.id %>">
                  <% if (project.tasks.length > 0) { %>
                    <% project.tasks.forEach(task => { %>
                      <div class="flex flex-col sm:flex-row sm:items-center justify-between p-6 hover:bg-slate-700/10 transition gap-4">
                        <div class="flex items-start space-x-4">
                          <div class="mt-1">
                            <% if (task.status === 'completed') { %>
                              <div class="w-5 h-5 rounded-full border-2 border-emerald-500 flex items-center justify-center text-[10px] text-emerald-500">
                                <i class="fas fa-check"></i>
                              </div>
                            <% } else if (task.status === 'in_progress') { %>
                              <div class="w-5 h-5 rounded-full border-2 border-blue-500 flex items-center justify-center text-[10px] text-blue-500">
                                <i class="fas fa-spinner animate-spin"></i>
                              </div>
                            <% } else { %>
                              <div class="w-5 h-5 rounded-full border-2 border-slate-600"></div>
                            <% } %>
                          </div>
                          <div>
                            <p class="font-bold text-white mb-1"><%= task.name %></p>
                            <div class="flex items-center space-x-3">
                              <span class="text-[10px] font-black uppercase tracking-widest px-2 py-0.5 rounded-md
                                <%= task.status === 'completed' ? 'bg-emerald-500/10 text-emerald-400' : 
                                    task.status === 'in_progress' ? 'bg-blue-500/10 text-blue-400' : 
                                    'bg-amber-500/10 text-amber-400' %>">
                                <%= task.status.replace('_', ' ') %>
                              </span>
                              <span class="text-xs text-slate-500">ID: #<%= task.id.slice(-4) %></span>
                            </div>
                          </div>
                        </div>
                        
                        <div class="flex items-center space-x-2 ml-9 sm:ml-0">
                          <button onclick="editTask('<%= task.id %>')" class="p-2 text-slate-400 hover:text-blue-400 hover:bg-blue-400/10 rounded-lg transition" title="Edit Task">
                            <i class="fas fa-pen-to-square"></i>
                          </button>
                          <button onclick="markDone('<%= task.id %>', this)" class="p-2 text-slate-400 hover:text-emerald-400 hover:bg-emerald-400/10 rounded-lg transition" title="Mark as Done">
                            <i class="fas fa-circle-check"></i>
                          </button>
                          <button onclick="deleteTask('<%= task.id %>', this)" class="p-2 text-slate-400 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition" title="Delete Task">
                            <i class="fas fa-trash-can"></i>
                          </button>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div class="p-8 text-center text-slate-500">
                      <i class="fas fa-clipboard-list text-2xl mb-2 opacity-20"></i>
                      <p class="text-sm">No tasks assigned to this project yet.</p>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          <% } else { %>
             <div class="text-center py-20 card-modern">
               <i class="fas fa-list-check text-5xl text-slate-700 mb-4"></i>
               <h4 class="text-xl font-bold text-white mb-2">No projects found</h4>
               <p class="text-slate-400">Create a project first to start adding tasks.</p>
             </div>
          <% } %>
        </div>
      </div>

      <!-- Budget Tab -->
      <div id="tab-budget" class="tab-content space-y-6 hidden">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
          <div>
            <h3 class="text-2xl font-bold text-white tracking-wide">💰 Budget Control</h3>
            <p class="text-slate-400 text-sm">Monitor your spending and stay within your financial goals.</p>
          </div>
          <a href="/budget" class="inline-flex items-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-6 py-2.5 rounded-xl font-bold text-sm transition btn-glow">
            <i class="fas fa-plus-circle"></i>
            <span>Configure Budget</span>
          </a>
        </div>

        <div class="space-y-6">
          <% projects.forEach(project => { %>
            <div class="card-modern overflow-hidden">
              <div class="flex justify-between items-center px-6 py-4 bg-slate-700/30 cursor-pointer budget-toggle group" data-project="<%= project.id %>">
                <div class="flex items-center space-x-3">
                  <div class="w-8 h-8 bg-emerald-500/20 rounded-lg flex items-center justify-center text-emerald-400">
                    <i class="fas fa-vault"></i>
                  </div>
                  <h4 class="text-lg font-bold text-white group-hover:text-emerald-400 transition"><%= project.name %></h4>
                </div>
                <i class="fas fa-chevron-down text-slate-500 transition-transform duration-300 budget-indicator"></i>
              </div>
              
              <div class="project-budgets mt-0 space-y-4 hidden p-6 border-t border-slate-700/50" data-project="<%= project.id %>">
                <% const projectBudgets = budgets.filter(b => b.project_id === project.id); %>
                <% if (projectBudgets.length > 0) { %>
                  <% projectBudgets.forEach(budget => { %>
                    <div class="bg-slate-900/50 rounded-2xl p-6 border border-slate-700/50">
                      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
                        <div>
                          <p class="text-xs font-black uppercase tracking-widest text-slate-500 mb-1">Total Allocated</p>
                          <h5 class="text-3xl font-bold text-white">KES <%= parseFloat(budget.totalBudget).toLocaleString() %></h5>
                        </div>
                        <div class="flex space-x-2">
                          <button onclick="editBudget('<%= budget.id %>')" class="flex items-center space-x-2 bg-slate-800 hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm transition">
                            <i class="fas fa-pen"></i> <span>Edit</span>
                          </button>
                          <button onclick="deleteBudget('<%= budget.id %>', this)" class="flex items-center space-x-2 bg-slate-800 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm transition">
                            <i class="fas fa-trash"></i> <span>Remove</span>
                          </button>
                        </div>
                      </div>
                      
                      <%
                        let components = [];
                        try {
                          components = JSON.parse(budget.components);
                        } catch (e) {
                          components = [];
                        }
                      %>
                      
                      <div class="mb-8">
                        <p class="text-sm font-bold text-slate-300 mb-4 flex items-center">
                          <i class="fas fa-tags mr-2 text-purple-400"></i>
                          Expense Breakdown
                        </p>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                          <% components.forEach(component => { %>
                            <div class="bg-slate-800/40 p-4 rounded-xl border border-slate-700/30">
                              <p class="text-slate-400 text-xs mb-1"><%= component.name %></p>
                              <p class="text-white font-bold">KES <%= parseFloat(component.cost).toLocaleString() %></p>
                            </div>
                          <% }) %>
                        </div>
                      </div>

                      <% const allocated = components.reduce((sum, comp) => sum + parseFloat(comp.cost || 0), 0); %>
                      <% const total = parseFloat(budget.totalBudget || 0); %>
                      <% const difference = allocated - total; %>
                      <% const percent = total > 0 ? (allocated / total) * 100 : 0; %>
                      
                      <div class="pt-6 border-t border-slate-700/50">
                        <div class="flex justify-between items-center mb-2 text-sm">
                          <span class="text-slate-400">Resource Allocation Status</span>
                          <span class="font-bold <%= percent > 100 ? 'text-red-400' : 'text-emerald-400' %>"><%= percent.toFixed(1) %>%</span>
                        </div>
                        <div class="w-full bg-slate-700 rounded-full h-3 overflow-hidden">
                          <div class="h-full rounded-full transition-all duration-1000 <%= percent > 100 ? 'bg-red-500' : 'bg-emerald-500' %>" style="width: <%= Math.min(percent, 100) %>%;"></div>
                        </div>
                        <p class="mt-4 text-xs">
                          <% if (difference === 0) { %>
                            <span class="bg-emerald-500/10 text-emerald-400 px-3 py-1 rounded-full"><i class="fas fa-check-circle mr-1"></i> Perfectly allocated</span>
                          <% } else if (difference > 0) { %>
                            <span class="bg-red-500/10 text-red-400 px-3 py-1 rounded-full"><i class="fas fa-exclamation-triangle mr-1"></i> Overallocated by KES <%= difference.toLocaleString() %></span>
                          <% } else { %>
                            <span class="bg-amber-500/10 text-amber-400 px-3 py-1 rounded-full"><i class="fas fa-info-circle mr-1"></i> Underallocated by KES <%= Math.abs(difference).toLocaleString() %></span>
                          <% } %>
                        </p>
                      </div>
                    </div>
                  <% }) %>
                <% } else { %>
                  <div class="text-center py-10">
                    <p class="text-slate-500 text-sm">No budget details configured for this project.</p>
                    <a href="/budget" class="text-purple-400 text-xs hover:underline mt-2 inline-block">Click here to set it up</a>
                  </div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

        <div id="tab-shop" class="tab-content space-y-6 hidden">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
            <div>
              <h3 class="text-2xl font-bold text-white tracking-wide">🛒 Material Shop</h3>
              <p class="text-slate-400 text-sm">Procure quality materials directly for your sites.</p>
            </div>
            <a href="/shop" class="inline-flex items-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-6 py-2.5 rounded-xl font-bold text-sm transition btn-glow">
              <i class="fas fa-store"></i>
              <span>Go to Shop</span>
            </a>
          </div>

          <div class="card-modern p-6">
            <div class="flex items-center space-x-4 mb-8 border-b border-slate-700/50 pb-4">
              <button class="sub-tab-button px-4 py-2 rounded-lg text-sm font-bold transition-all bg-purple-600 text-white" data-sub-tab="ongoing">
                <i class="fas fa-truck-fast mr-2"></i> Ongoing
              </button>
              <button class="sub-tab-button px-4 py-2 rounded-lg text-sm font-bold transition-all text-slate-400 hover:text-white hover:bg-slate-700/50" data-sub-tab="delivered">
                <i class="fas fa-box-open mr-2"></i> Delivered
              </button>
            </div>

            <div id="sub-tab-ongoing" class="sub-tab-content">
              <% if (ongoingOrders && ongoingOrders.length > 0) { %>
                <div class="overflow-x-auto rounded-xl border border-slate-700/50">
                  <table class="w-full text-left border-collapse">
                    <thead class="bg-slate-700/30 text-slate-400 text-xs uppercase tracking-widest font-black">
                      <tr>
                        <th class="px-6 py-4">Order ID</th>
                        <th class="px-6 py-4">Product</th>
                        <th class="px-6 py-4 text-center">Units</th>
                        <th class="px-6 py-4">Total Paid</th>
                        <th class="px-6 py-4">Status</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700/50 text-sm">
                      <% ongoingOrders.forEach(order => { %>
                        <tr class="hover:bg-slate-700/20 transition">
                          <td class="px-6 py-4 font-mono text-purple-400">#<%= order.id.slice(-6) %></td>
                          <td class="px-6 py-4 font-bold text-white"><%= order.product.name %></td>
                          <td class="px-6 py-4 text-center text-slate-300"><%= order.units %></td>
                          <td class="px-6 py-4 font-bold text-white">KES <%= parseFloat(order.amount_paid).toLocaleString() %></td>
                          <td class="px-6 py-4">
                            <span class="bg-blue-500/10 text-blue-400 px-3 py-1 rounded-full text-xs font-bold capitalize">
                              <%= order.status %>
                            </span>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <div class="text-center py-12">
                  <i class="fas fa-cart-shopping text-4xl text-slate-700 mb-4 opacity-20"></i>
                  <p class="text-slate-500">No ongoing orders at the moment.</p>
                </div>
              <% } %>
            </div>

            <div id="sub-tab-delivered" class="sub-tab-content hidden">
              <% if (deliveredOrders && deliveredOrders.length > 0) { %>
                <div class="overflow-x-auto rounded-xl border border-slate-700/50">
                  <table class="w-full text-left border-collapse">
                    <thead class="bg-slate-700/30 text-slate-400 text-xs uppercase tracking-widest font-black">
                      <tr>
                        <th class="px-6 py-4">Order ID</th>
                        <th class="px-6 py-4">Product</th>
                        <th class="px-6 py-4 text-center">Units</th>
                        <th class="px-6 py-4">Total Paid</th>
                        <th class="px-6 py-4">Delivered On</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700/50 text-sm">
                      <% deliveredOrders.forEach(order => { %>
                        <tr class="hover:bg-slate-700/20 transition">
                          <td class="px-6 py-4 font-mono text-emerald-400">#<%= order.id.slice(-6) %></td>
                          <td class="px-6 py-4 font-bold text-white"><%= order.product.name %></td>
                          <td class="px-6 py-4 text-center text-slate-300"><%= order.units %></td>
                          <td class="px-6 py-4 font-bold text-white">KES <%= parseFloat(order.amount_paid).toLocaleString() %></td>
                          <td class="px-6 py-4 text-slate-400"><%= order.delivered_date %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <div class="text-center py-12">
                  <i class="fas fa-box text-4xl text-slate-700 mb-4 opacity-20"></i>
                  <p class="text-slate-500">No delivered orders found.</p>
                </div>
              <% } %>
            </div>
          </div>
      </div>

      <div id="tab-teams" class="tab-content space-y-8 hidden">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
          <div>
            <h3 class="text-2xl font-bold text-white tracking-wide">👥 Workforce & Teams</h3>
            <p class="text-slate-400 text-sm">Collaborate with professionals and manage permissions.</p>
          </div>
          <a href="/invite-member" class="inline-flex items-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-6 py-2.5 rounded-xl font-bold text-sm transition btn-glow">
            <i class="fas fa-user-plus"></i>
            <span>Invite Professional</span>
          </a>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
          <div class="space-y-6">
            <h4 class="text-lg font-bold text-white flex items-center">
              <i class="fas fa-crown text-amber-400 mr-3"></i> Teams Managed by You
            </h4>
            <% if (projects.length > 0) { %>
              <% projects.forEach(project => { %>
                <div class="card-modern overflow-hidden">
                  <div class="flex justify-between items-center px-6 py-4 bg-slate-700/30 cursor-pointer team-by-you-toggle group" data-project="<%= project.id %>">
                    <h5 class="font-bold text-slate-300 group-hover:text-white transition"><%= project.name %></h5>
                    <i class="fas fa-plus text-xs text-slate-500 team-by-you-indicator transition-transform duration-300"></i>
                  </div>
                  <div class="project-teams-by-you hidden divide-y divide-slate-700/50" data-project="<%= project.id %>">
                    <% const projectTeams = teamsByYou.filter(t => t.project_id && t.project_id.id === project.id); %>
                    <% if (projectTeams.length > 0) { %>
                      <% projectTeams.forEach(team => { %>
                        <div class="p-4 flex items-center justify-between">
                          <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-slate-700 rounded-full flex items-center justify-center text-slate-400 font-bold">
                              <%= team.email.charAt(0).toUpperCase() %>
                            </div>
                            <div>
                              <p class="text-sm font-bold text-white truncate max-w-[150px]"><%= team.email %></p>
                              <p class="text-[10px] uppercase tracking-widest text-purple-400 font-black"><%= team.role %></p>
                            </div>
                          </div>
                          <span class="text-[10px] px-2 py-1 rounded-full font-bold <%= team.status === 'accepted' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-amber-500/10 text-amber-400' %>">
                            <%= team.status %>
                          </span>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <p class="p-6 text-center text-slate-500 text-sm italic">No members in this team yet.</p>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>

          <div class="space-y-6">
            <h4 class="text-lg font-bold text-white flex items-center">
              <i class="fas fa-handshake text-blue-400 mr-3"></i> External Team Invitations
            </h4>
            <%
              const groupedInvitedTo = {};
              teamsInvitedTo.forEach(team => {
                if (team.project_id) {
                  const projectId = team.project_id.id;
                  if (!groupedInvitedTo[projectId]) {
                    groupedInvitedTo[projectId] = { project: team.project_id, teams: [] };
                  }
                  groupedInvitedTo[projectId].teams.push(team);
                }
              });
              const invitedToProjects = Object.values(groupedInvitedTo);
            %>
            <% if (invitedToProjects.length > 0) { %>
              <% invitedToProjects.forEach(group => { %>
                <div class="card-modern overflow-hidden">
                  <div class="flex justify-between items-center px-6 py-4 bg-slate-700/30 cursor-pointer team-invited-to-toggle group" data-project="<%= group.project.id %>">
                    <h5 class="font-bold text-slate-300 group-hover:text-white transition"><%= group.project.name %></h5>
                    <i class="fas fa-plus text-xs text-slate-500 team-invited-to-indicator transition-transform duration-300"></i>
                  </div>
                  <div class="project-teams-invited-to hidden divide-y divide-slate-700/50" data-project="<%= group.project.id %>">
                    <% group.teams.forEach(team => { %>
                      <div class="p-4 flex items-center justify-between">
                        <div class="flex items-center space-x-3">
                          <div class="w-10 h-10 bg-blue-500/10 rounded-full flex items-center justify-center text-blue-400">
                            <i class="fas fa-id-badge"></i>
                          </div>
                          <div>
                            <p class="text-sm font-bold text-white"><%= team.role %></p>
                            <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold">Access Level</p>
                          </div>
                        </div>
                        <span class="text-[10px] px-2 py-1 rounded-full font-bold <%= team.status === 'accepted' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-amber-500/10 text-amber-400' %>">
                          <%= team.status %>
                        </span>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="card-modern p-12 text-center">
                <i class="fas fa-envelope-open text-3xl text-slate-700 mb-4 opacity-20"></i>
                <p class="text-slate-500 text-sm italic">You haven't received any project invitations.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Settings Tab -->
      <div id="tab-settings" class="tab-content card-modern overflow-hidden hidden">
        <!-- Profile Header -->
         <div class="relative h-48 md:h-64 overflow-hidden">
           <img id="cover-photo" src="<%= normalizeMediaUrl(user.profile_image) || 'https://picsum.photos/800/400/?blur=2' %>" alt="Cover Photo" class="w-full h-full object-cover opacity-60" />
           <div class="absolute inset-0 bg-gradient-to-t from-slate-900 to-transparent"></div>
           
           <!-- Profile Image Overlay -->
           <div class="absolute -bottom-12 left-8 md:left-12 flex items-end space-x-6">
             <div class="relative group">
               <img id="profile-image" src="<%= normalizeMediaUrl(user.profile_image) || 'https://picsum.photos/200/200/?blur=2' %>" alt="Profile Image" class="w-32 h-32 md:w-40 md:h-40 rounded-3xl object-cover border-4 border-slate-900 shadow-2xl" />
               <button class="absolute inset-0 bg-black/40 rounded-3xl opacity-0 group-hover:opacity-100 transition flex items-center justify-center text-white">
                 <i class="fas fa-camera text-2xl"></i>
               </button>
             </div>
             <div class="mb-14">
               <h3 class="text-2xl md:text-3xl font-bold text-white"><%= user.name %></h3>
               <p class="text-purple-400 font-medium"><%= user.email %></p>
             </div>
           </div>
        </div>

        <!-- Settings Grid -->
        <div class="pt-20 px-8 md:px-12 pb-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Account Details -->
          <div class="lg:col-span-2">
            <h4 class="text-xl font-bold text-white mb-8 flex items-center">
              <i class="fas fa-user-pen mr-3 text-purple-500"></i> Account Details
            </h4>
            <form id="user-details-form" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="name" class="text-xs font-black uppercase tracking-widest text-slate-500">Full Name</label>
                <input type="text" id="name" name="name" value="<%= user.name %>" required
                  class="w-full bg-slate-800 border border-slate-700 text-white px-4 py-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition" />
              </div>
              <div class="space-y-2">
                <label for="email" class="text-xs font-black uppercase tracking-widest text-slate-500">Email Address (Locked)</label>
                <input type="email" id="email" name="email" value="<%= user.email %>" readonly
                  class="w-full bg-slate-800/50 border border-slate-700/50 text-slate-500 px-4 py-3 rounded-xl cursor-not-allowed" />
              </div>
              <div class="space-y-2 md:col-span-2">
                <label for="phone" class="text-xs font-black uppercase tracking-widest text-slate-500">Phone Number</label>
                <input type="tel" id="phone" name="phone" value="<%= user.phone || '' %>"
                  class="w-full bg-slate-800 border border-slate-700 text-white px-4 py-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition" />
              </div>
              <div class="md:col-span-2 pt-4">
                <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-8 py-3 rounded-xl font-bold transition btn-glow">
                  Update Profile
                </button>
              </div>
            </form>
          </div>

          <!-- Quick Preferences -->
          <div class="space-y-8">
            <div>
              <h4 class="text-xl font-bold text-white mb-8 flex items-center">
                <i class="fas fa-shield-check mr-3 text-purple-500"></i> Verification
              </h4>
              <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-slate-800/50 rounded-xl border border-slate-700/50">
                  <div class="flex items-center space-x-3">
                    <i class="fas fa-envelope text-slate-500"></i>
                    <span class="text-sm font-medium">Email</span>
                  </div>
                  <button id="verify-email" class="text-xs font-bold text-purple-400 hover:text-purple-300 transition">Verify Now</button>
                </div>
                <div class="flex items-center justify-between p-4 bg-slate-800/50 rounded-xl border border-slate-700/50">
                  <div class="flex items-center space-x-3">
                    <i class="fas fa-phone text-slate-500"></i>
                    <span class="text-sm font-medium">Phone</span>
                  </div>
                  <button id="verify-phone" class="text-xs font-bold text-purple-400 hover:text-purple-300 transition">Verify Now</button>
                </div>
              </div>
            </div>

            <div>
              <h4 class="text-xl font-bold text-white mb-6 flex items-center">
                <i class="fas fa-palette mr-3 text-purple-500"></i> Appearance
              </h4>
              <div class="p-4 bg-purple-500/10 rounded-xl border border-purple-500/20">
                <p class="text-xs text-purple-300 leading-relaxed">
                  <i class="fas fa-moon mr-2"></i> Dark Mode is currently the default system theme for BuildOnBudget.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Notifications Tab -->
      <div id="tab-notifications" class="tab-content space-y-6 hidden">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h3 class="text-2xl font-bold text-white tracking-wide">🔔 Notifications</h3>
            <p class="text-slate-400 text-sm">Stay updated with team activities and project invites.</p>
          </div>
        </div>

        <% if (teamsInvitedTo && teamsInvitedTo.length > 0) { %>
          <div class="space-y-4">
            <% teamsInvitedTo.forEach(team => { %>
              <div class="card-modern p-6 <%= team.status === 'pending' ? 'border-purple-500/50 bg-purple-500/5' : '' %>">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6">
                  <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center <%= team.status === 'pending' ? 'bg-purple-500/20 text-purple-400' : 'bg-slate-700/50 text-slate-400' %>">
                      <i class="fas fa-envelope-open-text text-xl"></i>
                    </div>
                    <div>
                      <h4 class="font-bold text-white">Project Invitation</h4>
                      <p class="text-sm text-slate-400">
                        You've been invited to join <span class="text-purple-400 font-semibold"><%= team.project_id ? team.project_id.name : 'a new project' %></span> as a <span class="italic"><%= team.role %></span>.
                      </p>
                    </div>
                  </div>
                  <div class="flex items-center space-x-3 w-full sm:w-auto">
                    <% if (team.status === 'pending') { %>
                      <button onclick="acceptInvite('<%= team.id %>')" class="flex-1 sm:flex-none bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-lg font-bold text-sm transition shadow-lg shadow-purple-600/20">
                        Accept Invite
                      </button>
                    <% } else { %>
                      <span class="text-xs font-black uppercase tracking-widest text-emerald-400 bg-emerald-500/10 px-3 py-1 rounded-full">
                        <%= team.status %>
                      </span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="card-modern p-20 text-center">
            <div class="w-20 h-20 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-6">
              <i class="fas fa-bell-slash text-3xl text-slate-600"></i>
            </div>
            <h4 class="text-xl font-bold text-white mb-2">All caught up!</h4>
            <p class="text-slate-500">No new notifications for you right now.</p>
          </div>
        <% } %>
      </div>

    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Profile Dropdown Toggle
      const profileToggle = document.getElementById('profile-toggle');
      const profileDropdown = document.getElementById('profile-dropdown');
      
      if (profileToggle && profileDropdown) {
        profileToggle.addEventListener('click', (e) => {
          e.stopPropagation();
          profileDropdown.classList.toggle('hidden');
        });

        document.addEventListener('click', () => {
          profileDropdown.classList.add('hidden');
        });
      }

      // Tab Trigger from Dropdown
      document.querySelectorAll('.tab-trigger').forEach(trigger => {
        trigger.addEventListener('click', function(e) {
          const target = this.dataset.target;
          const tabButton = document.querySelector(`.tab-button[data-tab="${target}"]`);
          if (tabButton) tabButton.click();
        });
      });

      // User Details Form
      const userForm = document.getElementById('user-details-form');
      if (userForm) {
        userForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          const formData = new FormData(this);
          const data = Object.fromEntries(formData);
          delete data.email;

          try {
            const response = await fetch('/update-user', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
            const result = await response.json();
            if (response.ok) {
              showToast('Profile updated successfully', 'success');
              setTimeout(() => location.reload(), 1000);
            } else {
              showToast(result.error || 'Update failed', 'error');
            }
          } catch (error) {
            showToast('An error occurred', 'error');
          }
        });
      }

      // Verification Buttons
      document.getElementById('verify-email')?.addEventListener('click', () => showToast('Verification link sent to your email', 'success'));
      document.getElementById('verify-phone')?.addEventListener('click', () => showToast('SMS verification code sent', 'success'));
    });
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Global Chart Defaults
      Chart.defaults.color = '#94a3b8';
      Chart.defaults.font.family = "'Plus Jakarta Sans', sans-serif";

      // Task Status Chart
      const canvas1 = document.getElementById('taskStatusChart');
      if (canvas1) {
        const ctx1 = canvas1.getContext('2d');
        new Chart(ctx1, {
          type: 'doughnut',
          data: {
            labels: ['Pending', 'In Progress', 'Completed'],
            datasets: [{
              data: [
                parseInt(canvas1.dataset.pending) || 0, 
                parseInt(canvas1.dataset.inProgress) || 0, 
                parseInt(canvas1.dataset.completed) || 0
              ],
              backgroundColor: ['#f59e0b', '#3b82f6', '#10b981'],
              borderWidth: 0,
              hoverOffset: 15
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
            },
            cutout: '70%'
          }
        });
      }

      // Monthly Tasks Chart
      const canvas2 = document.getElementById('monthlyTasksChart');
      if (canvas2) {
        const ctx2 = canvas2.getContext('2d');
        const gradient = ctx2.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(139, 92, 246, 0.5)');
        gradient.addColorStop(1, 'rgba(139, 92, 246, 0)');

        new Chart(ctx2, {
          type: 'line',
          data: {
            labels: JSON.parse(canvas2.dataset.labels || '[]'),
            datasets: [{
              label: 'Completed Tasks',
              data: JSON.parse(canvas2.dataset.data || '[]'),
              borderColor: '#8b5cf6',
              backgroundColor: gradient,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#8b5cf6',
              pointRadius: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' } },
              x: { grid: { display: false } }
            },
            plugins: { legend: { display: false } }
          }
        });
      }
    });
  </script>
</body>
</html>

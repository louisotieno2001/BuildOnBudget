<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>BuildOnBudget - Home</title>
  <link href="/output.css" rel="stylesheet" />
  <link href="/styles.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Oswald:wght@200..700&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
  <link rel="shortcut icon" href="/images/logo.png" type="image">
  <script defer src="/javascript/index.js"></script>
  <style>
    :root {
      --font-heading: 'Oswald', sans-serif;
      --font-body: 'Plus Jakarta Sans', sans-serif;
      --font-accent: 'DM Sans', sans-serif;
    }
    body {
      font-family: var(--font-body);
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .font-accent {
      font-family: var(--font-accent);
    }
    .hero-gradient {
      background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #312e81 100%);
    }
    .hero-pattern {
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .float-animation {
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-20px); }
    }
    .glow-effect {
      box-shadow: 0 0 60px rgba(139, 92, 246, 0.3);
    }
    .btn-glow:hover {
      box-shadow: 0 0 30px rgba(139, 92, 246, 0.5);
    }
  </style>
</head>

<body class="bg-bg-primary text-text-primary min-h-screen flex flex-col font-body">
  <!-- Hero Section -->
  <section class="relative min-h-screen hero-gradient hero-pattern flex items-center">
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 left-10 w-72 h-72 bg-purple-500/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-indigo-500/20 rounded-full blur-3xl"></div>
    </div>

    <!-- Navigation -->
    <nav class="absolute top-0 left-0 right-0 z-50 px-6 lg:px-12 py-6">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center space-x-3">
          <img src="/images/logo.png" alt="Logo" class="w-12 h-12">
          <span class="text-xl font-bold text-white tracking-wide">BUILDON<span class="text-purple-400">BUDGET</span></span>
        </div>
        <div class="hidden md:flex items-center space-x-8">
          <a href="#features" class="text-slate-300 hover:text-white transition font-medium">Features</a>
          <a href="#how-it-works" class="text-slate-300 hover:text-white transition font-medium">How It Works</a>
          <a href="/demo" class="text-slate-300 hover:text-white transition font-medium">Demo</a>
          <a href="/login" class="text-slate-300 hover:text-white transition font-medium">Login</a>
          <a href="/signup" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-lg font-semibold transition btn-glow">Get Started</a>
        </div>
      </div>
    </nav>

    <!-- Hero Content -->
    <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-12 py-32 lg:py-40 w-full">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text Content -->
        <div class="text-center lg:text-left">
          <div class="inline-flex items-center space-x-2 bg-purple-500/20 border border-purple-500/30 rounded-full px-4 py-1 mb-6">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span class="text-purple-300 text-sm font-medium">Trusted by 500+ Construction Teams</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-tight mb-6">
            Build Smarter.<br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">Stay on Budget.</span>
          </h1>
          <p class="text-lg sm:text-xl text-slate-300 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
            Plan, track, and collaborate on your dream construction projects without worrying about overspending or fraud. Manage your budget seamlessly.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="/signup" class="inline-flex items-center justify-center space-x-2 bg-purple-600 hover:bg-purple-700 text-white px-8 py-4 rounded-xl font-bold text-lg transition btn-glow">
              <span>Start Free</span>
              <i class="fas fa-arrow-right"></i>
            </a>
            <a href="/demo" class="inline-flex items-center justify-center space-x-2 border-2 border-slate-600 hover:border-purple-400 text-white px-8 py-4 rounded-xl font-bold text-lg transition">
              <i class="fas fa-play"></i>
              <span>Watch Demo</span>
            </a>
          </div>
          
          <!-- Trust Indicators -->
          <div class="mt-10 pt-8 border-t border-slate-700/50">
            <p class="text-slate-400 text-sm mb-4">Trusted by companies worldwide</p>
            <div class="flex items-center justify-center lg:justify-start space-x-6">
              <div class="text-2xl font-bold text-slate-500"><i class="fas fa-building"></i> 500+</div>
              <div class="text-2xl font-bold text-slate-500"><i class="fas fa-users"></i> 10K+</div>
              <div class="text-2xl font-bold text-slate-500"><i class="fas fa-globe"></i> 20+</div>
            </div>
          </div>
        </div>

        <!-- Right: Phone Mockup & Stats -->
        <div class="flex justify-center">
          <div class="relative">
            <!-- Floating Stats Cards -->
            <div class="absolute -left-8 top-10 bg-white/10 backdrop-blur-md rounded-xl p-4 float-animation" style="animation-delay: 0s;">
              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                  <i class="fas fa-save text-green-400"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-400">Budget Saved</p>
                  <p class="text-white font-bold">$2.5M</p>
                </div>
              </div>
            </div>
            <div class="absolute -right-8 bottom-20 bg-white/10 backdrop-blur-md rounded-xl p-4 float-animation" style="animation-delay: 1s;">
              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center">
                  <i class="fas fa-tasks text-purple-400"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-400">Projects Done</p>
                  <p class="text-white font-bold">1,240</p>
                </div>
              </div>
            </div>
            <div class="absolute -left-4 bottom-0 bg-white/10 backdrop-blur-md rounded-xl p-4 float-animation" style="animation-delay: 2s;">
              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                  <i class="fas fa-users text-blue-400"></i>
                </div>
                <div>
                  <p class="text-xs text-slate-400">Team Members</p>
                  <p class="text-white font-bold">5,000+</p>
                </div>
              </div>
            </div>

            <!-- Phone Mockup -->
            <div class="relative w-72 h-[580px] rounded-[40px] border-8 border-slate-800 bg-slate-900 shadow-2xl glow-effect overflow-hidden">
              <div class="absolute top-3 left-1/2 -translate-x-1/2 w-24 h-6 bg-slate-800 rounded-b-xl"></div>
              <div class="flex flex-col items-center justify-center h-full p-6 bg-gradient-to-br from-purple-900 to-slate-900">
                <img src="/images/logo.png" alt="App Logo" class="w-24 h-24 mb-6 float-animation">
                <h3 class="text-2xl font-bold text-white mb-3 text-center">BuildOnBudget</h3>
                <p class="text-center text-slate-300 text-sm mb-6">Your construction companion for smart budgeting and project management</p>
                <div class="space-y-3 w-full">
                  <div class="flex items-center space-x-3 bg-white/10 rounded-lg p-3">
                    <i class="fas fa-wallet text-green-400 w-6"></i>
                    <span class="text-white text-sm">Budget Tracking</span>
                  </div>
                  <div class="flex items-center space-x-3 bg-white/10 rounded-lg p-3">
                    <i class="fas fa-users text-purple-400 w-6"></i>
                    <span class="text-white text-sm">Team Collaboration</span>
                  </div>
                  <div class="flex items-center space-x-3 bg-white/10 rounded-lg p-3">
                    <i class="fas fa-chart-line text-blue-400 w-6"></i>
                    <span class="text-white text-sm">Progress Analytics</span>
                  </div>
                </div>
                <button class="mt-6 w-full bg-purple-600 hover:bg-purple-700 text-white py-3 rounded-lg font-semibold transition">
                  Open App
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <a href="#features" class="text-white/50 hover:text-white transition">
        <i class="fas fa-chevron-down text-2xl"></i>
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="px-6 lg:px-12 py-20 bg-bg-primary">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-purple-600 font-semibold tracking-wider uppercase text-sm">Why Choose Us</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mt-2 mb-4">Everything You Need to Build Better</h2>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">Powerful features designed specifically for construction project managers and contractors.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-bg-secondary p-8 rounded-2xl shadow hover:shadow-xl transition group border border-transparent hover:border-purple-500/20">
          <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition">
            <i class="fas fa-shield-alt text-white text-2xl"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Budget Protection</h3>
          <p class="text-text-secondary">Your money stays safe. We ensure contractors don't overcharge and every expense is transparent with detailed breakdowns.</p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-bg-secondary p-8 rounded-2xl shadow hover:shadow-xl transition group border border-transparent hover:border-purple-500/20">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition">
            <i class="fas fa-users text-white text-2xl"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Team Collaboration</h3>
          <p class="text-text-secondary">Invite teammates, assign tasks, upload images, and collaborate in real time. Keep everyone on the same page.</p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-bg-secondary p-8 rounded-2xl shadow hover:shadow-xl transition group border border-transparent hover:border-purple-500/20">
          <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-emerald-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition">
            <i class="fas fa-chart-pie text-white text-2xl"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Project Tracking</h3>
          <p class="text-text-secondary">Track progress visually with real-time updates and analytics that keep your project on schedule.</p>
        </div>

        <!-- Feature 4 -->
        <div class="bg-bg-secondary p-8 rounded-2xl shadow hover:shadow-xl transition group border border-transparent hover:border-purple-500/20">
          <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-red-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition">
            <i class="fas fa-shopping-cart text-white text-2xl"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Material Procurement</h3>
          <p class="text-text-secondary">Browse and order construction materials directly from trusted suppliers. Get competitive pricing and reliable delivery.</p>
        </div>

        <!-- Feature 5 -->
        <div class="bg-bg-secondary p-8 rounded-2xl shadow hover:shadow-xl transition group border border-transparent hover:border-purple-500/20">
          <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition">
            <i class="fas fa-file-invoice-dollar text-white text-2xl"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Invoice Management</h3>
          <p class="text-text-secondary">Generate and track invoices easily. Keep all your financial documents organized in one place.</p>
        </div>

        <!-- Feature 6 -->
        <div class="bg-bg-secondary p-8 rounded-2xl shadow hover:shadow-xl transition group border border-transparent hover:border-purple-500/20">
          <div class="w-14 h-14 bg-gradient-to-br from-cyan-500 to-blue-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition">
            <i class="fas fa-mobile-alt text-white text-2xl"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Mobile App</h3>
          <p class="text-text-secondary">Access your projects from anywhere with our mobile app. Available on Android and iOS devices.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="px-6 lg:px-12 py-20 bg-gradient-to-br from-slate-900 to-slate-800 text-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-purple-400 font-semibold tracking-wider uppercase text-sm">How It Works</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mt-2 mb-4">Get Started in 3 Simple Steps</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl font-bold">1</div>
          <h3 class="text-xl font-bold mb-3">Create Account</h3>
          <p class="text-slate-400">Sign up for free and create your first project in minutes.</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl font-bold">2</div>
          <h3 class="text-xl font-bold mb-3">Add Your Team</h3>
          <p class="text-slate-400">Invite contractors and team members to collaborate.</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl font-bold">3</div>
          <h3 class="text-xl font-bold mb-3">Start Building</h3>
          <p class="text-slate-400">Track progress and manage budgets effectively.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="px-6 lg:px-12 py-20 bg-gradient-to-r from-purple-600 to-indigo-600 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6">Ready to Build Smarter?</h2>
      <p class="text-xl text-purple-100 mb-8">Join thousands of users who are building their dreams without breaking the bank.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="bg-white text-purple-700 px-10 py-4 rounded-xl font-bold shadow hover:bg-gray-100 transition">
          Get Started Free
        </a>
        <a href="/demo" class="border-2 border-white text-white px-10 py-4 rounded-xl font-bold hover:bg-white/10 transition">
          Watch Demo
        </a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

</body>

</html>
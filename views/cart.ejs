<!DOCTYPE html>
<html lang="en" class="scroll-smooth dark">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Your Cart - BuildOnBudget</title>
  <link href="/output.css" rel="stylesheet" />
  <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Oswald:wght@200..700&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
  <script defer src="/javascript/index.js"></script>
  <style>
    :root {
      --font-heading: 'Oswald', sans-serif;
      --font-body: 'Plus Jakarta Sans', sans-serif;
    }
    body {
      font-family: var(--font-body);
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .hero-gradient {
      background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #312e81 100%);
    }
    .card-modern {
      @apply bg-slate-800/40 backdrop-blur-md border border-slate-700/50 rounded-2xl transition-all duration-300;
    }
    .input-modern {
      @apply bg-slate-900/50 border border-slate-700 text-white px-4 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all;
    }
    .btn-glow:hover {
      box-shadow: 0 0 20px rgba(139, 92, 246, 0.4);
    }
  </style>
</head>

<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col">
  <div id="toast-container"></div>

  <!-- HEADER -->
  <header class="bg-slate-900/80 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
    <div class="flex justify-between items-center px-4 py-4 md:px-8 max-w-[1200px] mx-auto w-full">
      <div class="flex items-center space-x-4">
        <a href="/shop" class="flex items-center space-x-2 text-slate-400 hover:text-white transition-colors bg-slate-800/50 px-4 py-2 rounded-xl border border-slate-700/50">
          <i class="fas fa-arrow-left text-xs"></i>
          <span class="text-xs font-black uppercase tracking-widest hidden sm:block">Back to Shop</span>
        </a>
      </div>
      <div class="flex items-center space-x-3">
        <img src="/images/logo.png" alt="Logo" class="w-8 h-8">
        <span class="text-lg font-bold text-white tracking-tight">BUILDON<span class="text-purple-400">BUDGET</span></span>
      </div>
      <div class="hidden sm:block w-32"></div>
    </div>
  </header>

  <main class="flex-grow p-4 md:p-8 max-w-[1000px] mx-auto w-full space-y-8">
    <div class="flex items-end justify-between border-b border-slate-800 pb-6">
      <div>
        <h1 class="text-3xl md:text-5xl font-bold text-white tracking-tight"><%= user.name %>'s <span class="text-purple-500">Cart</span></h1>
        <p class="text-slate-500 text-sm font-bold uppercase tracking-widest mt-2">Review your selected construction materials</p>
      </div>
      <div class="text-right hidden md:block">
        <span class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Item Count</span>
        <p class="text-2xl font-bold text-white"><%= cartItems.length %></p>
      </div>
    </div>

    <% if (cartItems.length === 0) { %>
      <div class="card-modern p-20 text-center flex flex-col items-center">
        <div class="w-24 h-24 bg-slate-800 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-shopping-basket text-4xl text-slate-600"></i>
        </div>
        <h2 class="text-2xl font-bold text-white mb-2">Your cart is empty</h2>
        <p class="text-slate-500 mb-8 max-w-xs">It looks like you haven't added any materials to your cart yet.</p>
        <a href="/shop" class="bg-purple-600 hover:bg-purple-700 text-white px-8 py-3 rounded-xl font-bold transition btn-glow shadow-xl shadow-purple-600/20">
          Start Shopping
        </a>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        <!-- Cart Items List -->
        <div class="lg:col-span-2 space-y-4">
          <% cartItems.forEach(item => { 
               const mediaValue = item.media;
               const mediaId = (mediaValue && mediaValue.id) || (Array.isArray(mediaValue) ? ((mediaValue[0] && mediaValue[0].id) || mediaValue[0]) : mediaValue);
          %>
            <div class="cart-item card-modern p-4 flex items-center gap-6 group">
              <div class="relative w-24 h-24 flex-shrink-0 overflow-hidden rounded-xl border border-slate-700/50">
                <img src="<%= mediaId ? `/assets/${mediaId}` : '/images/cart.png' %>" alt="<%= item.name %>" class="w-full h-full object-cover transition-transform group-hover:scale-110" />
              </div>
              
              <div class="flex-grow">
                <div class="flex justify-between items-start">
                  <div>
                    <h3 class="text-lg font-bold text-white group-hover:text-purple-400 transition-colors"><%= item.name %></h3>
                    <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-2">Unit Price: KES <%= parseFloat(item.price).toLocaleString() %></p>
                  </div>
                  <button data-id="<%= item.order_id %>" class="remove-btn text-slate-500 hover:text-red-400 transition-colors p-2" title="Remove Item">
                    <i class="fas fa-trash-can"></i>
                  </button>
                </div>
                
                <div class="flex items-center justify-between mt-2">
                  <div class="flex items-center bg-slate-900/50 rounded-lg p-1 border border-slate-700/50">
                    <span class="text-[10px] font-black text-slate-500 uppercase px-2">Qty</span>
                    <input type="number" min="1" value="<%= item.quantity || 1 %>" data-id="<%= item.order_id %>"
                      class="quantity-input w-12 bg-transparent text-white font-bold text-center focus:outline-none" />
                  </div>
                  <div class="text-right">
                    <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest block">Subtotal</span>
                    <span class="item-total font-bold text-white">KES <%= (item.total || 0).toLocaleString() %></span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-1 space-y-6 sticky top-28">
          <div class="card-modern p-6 bg-slate-800/60">
            <h3 class="text-xl font-bold text-white mb-6 flex items-center">
              <i class="fas fa-file-invoice-dollar text-purple-500 mr-3"></i> Order Summary
            </h3>
            
            <div class="space-y-4 mb-8">
              <div class="flex justify-between text-sm">
                <span class="text-slate-400 font-medium">Subtotal</span>
                <span class="text-white font-bold">KES <%= cartItems.reduce((sum, item) => sum + (item.total || 0), 0).toLocaleString() %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-slate-400 font-medium">Delivery</span>
                <span class="text-emerald-400 font-bold uppercase text-[10px] tracking-widest">Calculated at Step 2</span>
              </div>
              <div class="pt-4 border-t border-slate-700/50 flex justify-between items-center">
                <span class="text-lg font-bold text-white">Total</span>
                <span id="overall-total" class="text-2xl font-bold text-purple-400">KES <%= cartItems.reduce((sum, item) => sum + (item.total || 0), 0).toLocaleString() %></span>
              </div>
            </div>

            <div class="space-y-4">
              <div>
                <label for="phone" class="text-[10px] font-black uppercase tracking-widest text-slate-500 ml-1 mb-2 block">M-Pesa Number</label>
                <div class="relative">
                  <i class="fas fa-mobile-screen-button absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
                  <input type="tel" id="phone" name="phone" required
                    class="input-modern w-full pl-10 text-sm"
                    placeholder="07xxxxxxxx" value="<%= user.phone || '' %>" />
                </div>
                <div id="phone-error" class="text-red-400 text-[10px] mt-2 hidden font-bold uppercase tracking-tight">
                  <i class="fas fa-circle-exclamation mr-1"></i> <span></span>
                </div>
              </div>

              <button id="checkout-btn" class="w-full bg-purple-600 hover:bg-purple-700 text-white py-4 rounded-xl font-bold transition btn-glow shadow-xl shadow-purple-600/20 flex items-center justify-center space-x-2">
                <i class="fas fa-lock text-xs"></i>
                <span>Secure Checkout</span>
              </button>
            </div>
            
            <div class="mt-6 flex flex-col items-center space-y-4">
               <img src="/images/cart.png" alt="M-Pesa" class="h-8 opacity-50 grayscale hover:grayscale-0 transition-all cursor-help" title="Lipa na M-Pesa supported" />
               <p class="text-[10px] text-slate-500 text-center uppercase tracking-tighter leading-relaxed">
                 By clicking checkout, you will receive an STK push notification on your phone to complete the transaction.
               </p>
            </div>
          </div>
          
          <div class="card-modern p-4 border-emerald-500/20 bg-emerald-500/5">
            <div class="flex items-start space-x-3">
              <i class="fas fa-truck-fast text-emerald-400 mt-1"></i>
              <div>
                <p class="text-xs font-bold text-white uppercase tracking-tight">Rapid Site Delivery</p>
                <p class="text-[10px] text-slate-400 mt-1 uppercase tracking-tighter font-black leading-tight">Delivery is scheduled immediately after payment confirmation.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>

  <script src="/javascript/cart.js"></script>
  <script src="/javascript/toast.js"></script>
</body>

</html>

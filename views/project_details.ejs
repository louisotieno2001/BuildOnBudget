<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Project Details - BuildOnBudget</title>
  <link href="/output.css" rel="stylesheet" />
  <link href="/styles.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Oswald:wght@200..700&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
  <link rel="shortcut icon" href="/images/logo.png" type="image">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.11.338/pdf.min.js"></script>
  <script defer src="/javascript/index.js"></script>
  <style>
    :root {
      --font-heading: 'Oswald', sans-serif;
      --font-body: 'Plus Jakarta Sans', sans-serif;
      --font-accent: 'DM Sans', sans-serif;
    }
    body {
      font-family: var(--font-body);
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .hero-gradient {
      background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #312e81 100%);
    }
    .hero-pattern {
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .glow-effect {
      box-shadow: 0 0 60px rgba(139, 92, 246, 0.3);
    }
    .btn-glow:hover {
      box-shadow: 0 0 30px rgba(139, 92, 246, 0.5);
    }
  </style>
</head>

<body x-data="{ sidebarOpen: false, profileOpen: false }" class="bg-bg-primary text-text-primary min-h-screen flex flex-col font-body">

  <section class="relative min-h-[30vh] hero-gradient hero-pattern flex items-center">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-10 left-10 w-48 h-48 bg-purple-500/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-64 h-64 bg-indigo-500/20 rounded-full blur-3xl"></div>
    </div>

    <nav class="absolute top-0 left-0 right-0 z-50 px-6 lg:px-12 py-4">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center space-x-3">
          <img src="/images/logo.png" alt="Logo" class="w-10 h-10">
          <span class="text-lg font-bold text-white tracking-wide">BUILDON<span class="text-purple-400">BUDGET</span></span>
        </div>
        <div class="hidden md:flex items-center space-x-6">
          <a href="/dashboard" class="text-slate-300 hover:text-white transition font-medium"><i class="fas fa-home mr-2"></i>Dashboard</a>
          <a href="/logout" class="text-slate-300 hover:text-white transition font-medium"><i class="fas fa-sign-out-alt mr-2"></i>Logout</a>
        </div>
      </div>
    </nav>

    <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-12 py-24 w-full">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <a href="/dashboard" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg transition border border-white/20">
          <i class="fas fa-arrow-left"></i>
          Back to Dashboard
        </a>
        <h1 class="text-2xl sm:text-3xl font-bold text-white"><%= project.name %></h1>
      </div>
    </div>
  </section>

  <main class="flex-1 px-4 sm:px-6 lg:px-12 py-8">
    <div class="max-w-6xl mx-auto space-y-6">
      <div class="bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
        <div class="mb-6">
          <h2 class="text-xl font-semibold text-white mb-2"><i class="fas fa-info-circle text-purple-400 mr-2"></i>Description</h2>
          <p class="text-slate-400"><%= project.description %></p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-wallet text-green-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Budget</p>
                <p class="text-white font-semibold">Ksh <%= project.budget %></p>
              </div>
            </div>
          </div>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-calendar-start text-blue-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Start Date</p>
                <p class="text-white font-semibold"><%= new Date(project.start_date).toLocaleDateString() %></p>
              </div>
            </div>
          </div>

          <% if (project.deadline) { %>
          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-red-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-calendar-end text-red-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">End Date</p>
                <p class="text-white font-semibold"><%= new Date(project.deadline).toLocaleDateString() %></p>
              </div>
            </div>
          </div>
          <% } %>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-user text-purple-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Client Name</p>
                <p class="text-white font-semibold"><%= project.client_name %></p>
              </div>
            </div>
          </div>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-phone text-cyan-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Client Contact</p>
                <p class="text-white font-semibold"><%= project.client_contact %></p>
              </div>
            </div>
          </div>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-yellow-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-map-marker-alt text-yellow-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Location</p>
                <p class="text-white font-semibold"><%= project.location %></p>
              </div>
            </div>
          </div>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-pink-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-boxes text-pink-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Materials</p>
                <p class="text-white font-semibold"><%= project.materials %></p>
              </div>
            </div>
          </div>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-indigo-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-hard-hat text-indigo-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Contractors</p>
                <p class="text-white font-semibold"><%= project.contractors %></p>
              </div>
            </div>
          </div>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-orange-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-file-contract text-orange-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Permits</p>
                <p class="text-white font-semibold"><%= project.permits %></p>
              </div>
            </div>
          </div>

          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <div class="flex items-center space-x-3 mb-2">
              <div class="w-10 h-10 bg-teal-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-shield-alt text-teal-400"></i>
              </div>
              <div>
                <p class="text-sm text-slate-400">Safety</p>
                <p class="text-white font-semibold"><%= project.safety %></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% if (project.attachment_base64) { %>
      <div class="bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
        <h2 class="text-xl font-semibold text-white mb-4"><i class="fas fa-paperclip text-purple-400 mr-2"></i>Attachments</h2>
        <div class="bg-white/5 rounded-xl p-4 border border-white/10">
          <% if (project.attachment_type && project.attachment_type.startsWith('image/')) { %>
          <img src="/projects/<%= project.id %>/attachment" alt="Project attachment" class="w-full max-h-[700px] object-contain rounded-lg" />
          <% } else { %>
          <iframe src="/projects/<%= project.id %>/attachment" width="100%" height="600px" class="rounded-lg"></iframe>
          <% } %>
        </div>
      </div>
      <% } %>

      <div class="bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
        <h2 class="text-xl font-semibold text-white mb-2"><i class="fas fa-cube text-purple-400 mr-2"></i>3D Visualization</h2>
        <p class="text-slate-400 mb-4">Upload BOQ, house plans to generate interactive 3D model and track progress.</p>
        <a href="/dashboard/projects/<%= project.id %>/3d" class="inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-xl font-semibold transition btn-glow">
          <i class="fas fa-cubes"></i>
          Open 3D Viewer
        </a>
      </div>
    </div>
  </main>
</body>

</html>
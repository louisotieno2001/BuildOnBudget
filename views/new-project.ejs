<!DOCTYPE html>
<html lang="en" class="scroll-smooth dark">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Create New Project - BuildOnBudget</title>
    <link href="/output.css" rel="stylesheet" />
    <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Oswald:wght@200..700&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
    <style>
        :root {
            --font-heading: 'Oswald', sans-serif;
            --font-body: 'Plus Jakarta Sans', sans-serif;
        }
        body {
            font-family: var(--font-body);
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: var(--font-heading);
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }
        .hero-gradient {
            background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #312e81 100%);
        }
        .hero-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .card-modern {
            @apply bg-slate-800/30 backdrop-blur-2xl border border-slate-700/30 rounded-3xl shadow-2xl;
        }
        .input-modern {
            @apply w-full bg-slate-900/80 text-white px-5 py-4 rounded-2xl transition-all placeholder:text-slate-600 text-sm border-none ring-0 outline-none focus:ring-2 focus:ring-purple-500/30;
        }
        .label-modern {
            @apply block mb-3 text-xs font-black uppercase tracking-widest text-slate-500 ml-1;
        }
        .btn-glow:hover {
            box-shadow: 0 0 30px rgba(139, 92, 246, 0.4);
        }
        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1);
            opacity: 0.4;
            cursor: pointer;
        }
        /* Remove default outlines globally for inputs and textareas */
        input:focus, textarea:focus, select:focus {
            outline: none !important;
            box-shadow: none !important;
        }
        .input-focus-effect:focus-within {
            @apply ring-2 ring-purple-500/40;
        }
    </style>
</head>

<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col">
    <div id="toast-container"></div>
    
    <!-- Background Elements -->
    <div class="fixed inset-0 z-0 hero-gradient hero-pattern opacity-30"></div>
    <div class="fixed inset-0 z-0">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_10%,rgba(139,92,246,0.15),transparent)]"></div>
    </div>

    <!-- Main Content -->
    <main class="relative z-10 flex-grow flex items-center justify-center px-4 py-16">
        <div class="w-full max-w-4xl card-modern p-8 md:p-14">
            <!-- Header Section -->
            <div class="text-center mb-16">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-purple-500/10 rounded-3xl mb-8 text-purple-400 text-4xl shadow-2xl shadow-purple-500/20">
                    <i class="fas fa-drafting-compass"></i>
                </div>
                <h2 class="text-4xl md:text-6xl font-bold text-white mb-4 tracking-tighter italic">Initiate <span class="text-purple-500 not-italic">Project</span></h2>
                <p class="text-slate-500 text-sm font-medium max-w-lg mx-auto uppercase tracking-widest">Digital Blueprinting & Site Initialization</p>
            </div>

            <form id="new-project-form" class="space-y-12">
                
                <!-- Section 1: Core Project Identity -->
                <div class="space-y-8">
                    <div class="flex items-center space-x-4 mb-2">
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500">Project Identity</span>
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="md:col-span-2">
                            <label for="name" class="label-modern">Project Designation</label>
                            <div class="relative input-focus-effect rounded-2xl">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-600">
                                    <i class="fas fa-signature"></i>
                                </span>
                                <input type="text" id="name" name="name" required class="input-modern pl-14" placeholder="e.g., SkyTower Residential Complex">
                            </div>
                        </div>

                        <div class="flex flex-col">
                            <label for="type" class="label-modern">Architecture Classification</label>
                            <div class="relative input-focus-effect rounded-2xl">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-600 pointer-events-none">
                                    <i class="fas fa-city text-xs"></i>
                                </span>
                                <select id="type" name="type" required class="input-modern pl-14 appearance-none cursor-pointer">
                                    <option value="" class="bg-slate-900">-- Select Category --</option>
                                    <option value="residential" class="bg-slate-900">Residential</option>
                                    <option value="commercial" class="bg-slate-900">Commercial</option>
                                    <option value="infrastructure" class="bg-slate-900">Infrastructure</option>
                                    <option value="renovation" class="bg-slate-900">Renovation</option>
                                    <option value="industrial" class="bg-slate-900">Industrial</option>
                                </select>
                                <span class="absolute right-5 top-1/2 -translate-y-1/2 text-slate-600 pointer-events-none">
                                    <i class="fas fa-caret-down"></i>
                                </span>
                            </div>
                        </div>

                        <div class="flex flex-col">
                            <label for="location" class="label-modern">Geographic Coordinates / Site</label>
                            <div class="relative input-focus-effect rounded-2xl">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-600">
                                    <i class="fas fa-map-location-dot"></i>
                                </span>
                                <input type="text" id="location" name="location" required class="input-modern pl-14" placeholder="City, Address, Plot No.">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Client & Financial Framework -->
                <div class="space-y-8">
                    <div class="flex items-center space-x-4 mb-2">
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500">Stakeholder & Budget</span>
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <div class="flex flex-col">
                            <label for="client_name" class="label-modern">Client Principal</label>
                            <input type="text" id="client_name" name="client_name" class="input-modern" placeholder="Legal full name">
                        </div>
                        <div class="flex flex-col">
                            <label for="client_contact" class="label-modern">Contact Protocol</label>
                            <input type="text" id="client_contact" name="client_contact" class="input-modern" placeholder="Phone or Email">
                        </div>
                        <div class="flex flex-col">
                            <label for="budget" class="label-modern">Estimated Capital (KES)</label>
                            <div class="relative input-focus-effect rounded-2xl">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-600 text-xs font-bold">KES</span>
                                <input type="number" id="budget" name="budget" required min="0" class="input-modern pl-14" placeholder="0.00">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Technical Scope & Description -->
                <div class="space-y-8">
                    <div class="flex items-center space-x-4 mb-2">
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500">Mission Parameters</span>
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                    </div>
                    <div class="flex flex-col">
                        <label for="description" class="label-modern">Detailed Project Scope</label>
                        <div class="p-1 bg-gradient-to-br from-purple-500/20 to-transparent rounded-[1.4rem]">
                            <textarea id="description" name="description" rows="5" class="input-modern resize-none !bg-slate-950/80" placeholder="E.g., Comprehensive 10-floor structural development including foundation, mechanical, and finishing phases..."></textarea>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="flex flex-col">
                            <label for="start_date" class="label-modern">Commencement Date</label>
                            <input type="date" id="start_date" name="start_date" required class="input-modern">
                        </div>
                        <div class="flex flex-col">
                            <label for="end_date" class="label-modern">Target Handover</label>
                            <input type="date" id="end_date" name="end_date" class="input-modern">
                        </div>
                    </div>
                </div>

                <!-- Section 4: Resource Management -->
                <div class="space-y-8">
                    <div class="flex items-center space-x-4 mb-2">
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500">Resources & Logistics</span>
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                    </div>
                    <div class="flex flex-col">
                        <label for="materials" class="label-modern">Material Requirements</label>
                        <textarea id="materials" name="materials" rows="3" class="input-modern resize-none" placeholder="Cement, Reinforcement Steel, Grade A Sand..."></textarea>
                    </div>
                    <div class="flex flex-col">
                        <label for="contractors" class="label-modern">Workforce / Specialist Teams</label>
                        <textarea id="contractors" name="contractors" rows="3" class="input-modern resize-none" placeholder="Structural Engineers, MEP Contractors, Masonry..."></textarea>
                    </div>
                </div>

                <!-- Section 5: Compliance & Safety -->
                <div class="space-y-8">
                    <div class="flex items-center space-x-4 mb-2">
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500">Statutory Compliance</span>
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                    </div>
                    <div class="grid grid-cols-1 gap-8">
                        <div class="flex flex-col">
                            <label for="permits" class="label-modern">Regulatory Permits</label>
                            <textarea id="permits" name="permits" rows="2" class="input-modern resize-none" placeholder="NEMA, NCA, County Approvals..."></textarea>
                        </div>
                        <div class="flex flex-col">
                            <label for="safety" class="label-modern">Health & Safety Protocols</label>
                            <textarea id="safety" name="safety" rows="2" class="input-modern resize-none" placeholder="Site insurance, PPE requirements, safety barriers..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Section 6: Additional Data -->
                <div class="space-y-8">
                    <div class="flex items-center space-x-4 mb-2">
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500">Additional Specifications</span>
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                    </div>
                    <div class="flex flex-col">
                        <label for="notes" class="label-modern">Project Technical Notes</label>
                        <textarea id="notes" name="notes" rows="4" class="input-modern resize-none" placeholder="Any specific technical considerations, terrain details, or special client requests..."></textarea>
                    </div>
                </div>

                <!-- Section 7: Blueprints -->
                <div class="space-y-8">
                    <div class="flex items-center space-x-4 mb-2">
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-500">Digital Dossier</span>
                        <div class="h-px flex-1 bg-slate-700/50"></div>
                    </div>
                    <div class="relative group">
                        <div class="flex flex-col items-center justify-center w-full h-44 rounded-[2rem] bg-slate-950/60 group-hover:bg-slate-950 transition-all duration-300 border-none ring-2 ring-slate-800/50 group-hover:ring-purple-500/30">
                            <div class="flex flex-col items-center justify-center">
                                <i class="fas fa-file-invoice text-3xl text-slate-700 group-hover:text-purple-500 mb-4 transition-colors"></i>
                                <p class="text-[10px] text-slate-600 uppercase tracking-[0.3em] font-black">Archive Upload (PDF Only)</p>
                            </div>
                            <input type="file" id="attachments" name="attachments" accept=".pdf" class="absolute inset-0 opacity-0 cursor-pointer">
                        </div>
                    </div>
                    <p class="text-[9px] text-slate-600 text-center uppercase tracking-widest font-bold">
                        Merge all drawings using <a href="https://www.ilovepdf.com" target="_blank" class="text-slate-400 underline">iLovePDF</a> before site synchronization.
                    </p>
                </div>

                <!-- Action Matrix -->
                <div class="pt-12 flex flex-col md:flex-row items-center gap-8">
                    <button type="submit" id="create-project-button" class="w-full md:flex-[2] bg-purple-600 hover:bg-purple-700 text-white py-5 rounded-2xl font-bold text-lg transition-all btn-glow shadow-2xl shadow-purple-900/40 flex items-center justify-center space-x-4">
                        <i class="fas fa-satellite-dish text-sm"></i>
                        <span>Synchronize & Launch</span>
                    </button>
                    <a href="/dashboard" class="w-full md:flex-1 py-5 rounded-2xl font-bold text-slate-500 hover:text-white transition-all text-center text-xs uppercase tracking-[0.2em]">
                        Abort Session
                    </a>
                </div>
            </form>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="/javascript/toast.js"></script>
    <script src="/javascript/new-project.js"></script>
</body>

</html>

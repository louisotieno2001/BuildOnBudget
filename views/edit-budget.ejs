<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit Budget - BuildOnBudget</title>
    <link href="/output.css" rel="stylesheet" />
    <link href="/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Oswald:wght@200..700&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
    <link rel="shortcut icon" href="/images/logo.png" type="image">
    <script defer src="/javascript/index.js"></script>
    <style>
        :root {
            --font-heading: 'Oswald', sans-serif;
            --font-body: 'Plus Jakarta Sans', sans-serif;
            --font-accent: 'DM Sans', sans-serif;
        }
        body {
            font-family: var(--font-body);
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: var(--font-heading);
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }
        .hero-gradient {
            background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #312e81 100%);
        }
        .hero-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .glow-effect {
            box-shadow: 0 0 60px rgba(139, 92, 246, 0.3);
        }
        .btn-glow:hover {
            box-shadow: 0 0 30px rgba(139, 92, 246, 0.5);
        }
    </style>
</head>

<body class="bg-bg-primary text-text-primary min-h-screen flex flex-col font-body">
    <div id="toast-container"></div>
    
    <section class="relative min-h-[30vh] hero-gradient hero-pattern flex items-center">
        <div class="absolute inset-0 overflow-hidden">
            <div class="absolute top-10 left-10 w-48 h-48 bg-purple-500/20 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-64 h-64 bg-indigo-500/20 rounded-full blur-3xl"></div>
        </div>

        <nav class="absolute top-0 left-0 right-0 z-50 px-6 lg:px-12 py-4">
            <div class="max-w-7xl mx-auto flex justify-between items-center">
                <div class="flex items-center space-x-3">
                    <img src="/images/logo.png" alt="Logo" class="w-10 h-10">
                    <span class="text-lg font-bold text-white tracking-wide">BUILDON<span class="text-purple-400">BUDGET</span></span>
                </div>
                <div class="hidden md:flex items-center space-x-6">
                    <a href="/dashboard" class="text-slate-300 hover:text-white transition font-medium"><i class="fas fa-home mr-2"></i>Dashboard</a>
                    <a href="/logout" class="text-slate-300 hover:text-white transition font-medium"><i class="fas fa-sign-out-alt mr-2"></i>Logout</a>
                </div>
            </div>
        </nav>

        <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-12 py-24 w-full text-center">
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Edit Budget</h1>
            <p class="text-slate-400">Update your project budget details</p>
        </div>
    </section>

    <main class="flex-1 px-4 sm:px-6 lg:px-12 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 sm:p-8 border border-white/10 glow-effect">
                <form id="edit-budget-form" class="space-y-6">
                    <div>
                        <label for="project_id" class="block mb-2 font-medium text-slate-300">Select Project</label>
                        <select id="project_id" name="project_id" required
                            class="w-full bg-white/10 border border-white/20 px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 text-white">
                            <option value="" class="bg-slate-800">-- Select Project --</option>
                            <% projects.forEach(project=> { %>
                                <option value="<%= project.id %>" <%=project.id===budget.project_id ? 'selected' : '' %> class="bg-slate-800">
                                    <%= project.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div>
                        <label for="totalBudget" class="block mb-2 font-medium text-slate-300">Total Budget</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"><i class="fas fa-wallet"></i></span>
                            <input type="number" id="totalBudget" name="totalBudget" required min="0" step="0.01"
                                class="w-full bg-white/10 border border-white/20 pl-12 pr-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 text-white placeholder-slate-400"
                                value="<%= budget.totalBudget %>" />
                        </div>
                    </div>

                    <div>
                        <label for="components" class="block mb-2 font-medium text-slate-300">Components (JSON format)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-4 text-slate-400"><i class="fas fa-list"></i></span>
                            <textarea id="components" name="components" rows="6"
                                class="w-full bg-white/10 border border-white/20 pl-12 pr-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 text-white placeholder-slate-400 placeholder-textarea"
                                placeholder='[{"name":"Materials","cost":2000},{"name":"Labor","cost":3000}]'><%= budget.components %></textarea>
                        </div>
                    </div>

                    <button type="submit" id="update-budget-button"
                        class="w-full bg-purple-600 text-white py-3 rounded-lg font-semibold hover:bg-purple-700 transition btn-glow cursor-pointer">
                        <i class="fas fa-save mr-2"></i>Update Budget
                    </button>
                </form>

                <div class="mt-6 text-center">
                    <button id="delete-budget-button"
                        class="bg-red-500/20 hover:bg-red-500 text-red-400 hover:text-white px-6 py-3 rounded-lg font-semibold transition border border-red-500/30 hover:border-red-500 cursor-pointer">
                        <i class="fas fa-trash-alt mr-2"></i>Delete Budget
                    </button>
                </div>

                <p class="mt-6 text-center text-slate-400">
                    <a href="/dashboard" class="text-purple-400 hover:text-purple-300 transition"><i class="fas fa-arrow-left mr-2"></i>Back to Dashboard</a>
                </p>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    
    <script src="/javascript/toast.js"></script>
    <script>
        document.getElementById('edit-budget-form').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            const budgetId = '<%= budget.id %>';

            const button = document.getElementById('update-budget-button');
            button.disabled = true;
            button.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Updating...';

            try {
                const response = await fetch(`/edit-budget/${budgetId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (response.ok) {
                    showToast('Budget updated successfully', 'success');
                    setTimeout(() => window.location.href = '/dashboard', 1000);
                } else {
                    showToast(result.error || 'Error updating budget', 'error');
                    button.disabled = false;
                    button.innerHTML = '<i class="fas fa-save mr-2"></i>Update Budget';
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('An error occurred', 'error');
                button.disabled = false;
                button.innerHTML = '<i class="fas fa-save mr-2"></i>Update Budget';
            }
        });

        document.getElementById('delete-budget-button').addEventListener('click', async function () {
            if (!confirm('Are you sure you want to delete this budget?')) {
                return;
            }
            const budgetId = '<%= budget.id %>';
            const button = this;
            button.disabled = true;
            button.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Deleting...';

            try {
                const response = await fetch(`/budget/${budgetId}`, {
                    method: 'DELETE'
                });

                const result = await response.json();
                if (response.ok) {
                    showToast('Budget deleted successfully', 'success');
                    setTimeout(() => window.location.href = '/dashboard', 1000);
                } else {
                    showToast(result.error || 'Error deleting budget', 'error');
                    button.disabled = false;
                    button.innerHTML = '<i class="fas fa-trash-alt mr-2"></i>Delete Budget';
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('An error occurred', 'error');
                button.disabled = false;
                button.innerHTML = '<i class="fas fa-trash-alt mr-2"></i>Delete Budget';
            }
        });
    </script>
</body>

</html>
<!DOCTYPE html>
<html lang="en" class="scroll-smooth dark">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Material Procurement - BuildOnBudget</title>
  <link href="/output.css" rel="stylesheet" />
  <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Oswald:wght@200..700&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
  <script defer src="/javascript/index.js"></script>
  <script src="/javascript/toast.js"></script>
  <script defer src="/javascript/shop.js"></script>
  <style>
    :root {
      --font-heading: 'Oswald', sans-serif;
      --font-body: 'Plus Jakarta Sans', sans-serif;
    }
    body {
      font-family: var(--font-body);
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .hero-gradient {
      background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #312e81 100%);
    }
    .card-modern {
      @apply bg-slate-800/40 backdrop-blur-md border border-slate-700/50 rounded-2xl transition-all duration-300;
    }
    .card-modern:hover {
      @apply border-purple-500/30 shadow-xl shadow-purple-500/10 -translate-y-1;
    }
    .input-modern {
      @apply bg-slate-900/50 border border-slate-700 text-white px-4 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all;
    }
    .btn-glow:hover {
      box-shadow: 0 0 20px rgba(139, 92, 246, 0.4);
    }
    /* Hide scrollbar but keep functionality */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>

<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col">
  <div id="toast-container"></div>

  <!-- HEADER -->
  <header class="bg-slate-900/80 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
    <div class="flex justify-between items-center px-4 py-3 md:px-8 max-w-[1600px] mx-auto w-full">
      <!-- Left: Navigation + Brand -->
      <div class="flex items-center space-x-4">
        <a href="/dashboard" class="flex items-center space-x-2 text-slate-400 hover:text-white transition-colors bg-slate-800/50 px-3 py-1.5 rounded-xl border border-slate-700/50">
          <i class="fas fa-arrow-left text-xs"></i>
          <span class="text-xs font-black uppercase tracking-widest hidden sm:block">Dashboard</span>
        </a>
        <button id="sidebar-toggle" class="md:hidden text-slate-300 hover:text-white transition-colors p-2">
          <i class="fas fa-filter text-lg"></i>
        </button>
        <div class="hidden md:flex items-center space-x-3">
          <img src="/images/logo.png" alt="Logo" class="w-10 h-10">
          <span class="text-xl font-bold text-white tracking-tight">BUILDON<span class="text-purple-400">BUDGET</span></span>
        </div>
      </div>

      <!-- Right: Cart + Profile -->
      <div class="flex items-center space-x-3 sm:space-x-6">
        <a href="/cart" class="relative group p-2 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-purple-500/50 transition-all">
          <i class="fas fa-shopping-basket text-slate-300 group-hover:text-purple-400 transition-colors"></i>
          <span id="cart-count" class="absolute -top-1.5 -right-1.5 bg-purple-600 text-white text-[10px] font-black rounded-full h-5 w-5 flex items-center justify-center shadow-lg border-2 border-slate-900">
            <%= cartCount %>
          </span>
        </a>
        
        <div class="relative group">
          <button id="profile-toggle" class="flex items-center focus:outline-none">
            <img src="<%= normalizeMediaUrl(user.profile_image) || 'https://picsum.photos/200/300/?blur=2' %>"
                 class="w-10 h-10 rounded-full border-2 border-purple-500/50 object-cover shadow-lg">
          </button>
          <!-- Profile Dropdown -->
          <div id="profile-dropdown" class="absolute right-0 mt-3 w-56 bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl py-2 hidden overflow-hidden z-[60]">
            <div class="px-4 py-3 border-b border-slate-700 mb-1">
              <p class="text-sm font-semibold text-white"><%= user.name %></p>
              <p class="text-xs text-slate-500 truncate"><%= user.email %></p>
            </div>
            <a href="/" class="flex items-center px-4 py-2 text-sm text-slate-300 hover:bg-purple-600 hover:text-white transition">
              <i class="fas fa-home w-5 text-center mr-3"></i> Home
            </a>
            <a href="/dashboard#settings" class="flex items-center px-4 py-2 text-sm text-slate-300 hover:bg-purple-600 hover:text-white transition">
              <i class="fas fa-cog w-5 text-center mr-3"></i> Settings
            </a>
            <div class="border-t border-slate-700 mt-1">
              <a href="/logout" class="flex items-center px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 transition">
                <i class="fas fa-sign-out-alt w-5 text-center mr-3"></i> Logout
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="flex flex-1 max-w-[1600px] mx-auto w-full">

    <!-- MOBILE OVERLAY -->
    <div id="mobile-overlay" class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm md:hidden z-40 hidden"></div>

    <!-- SIDEBAR -->
    <aside id="sidebar" class="fixed md:static inset-y-0 left-0 w-72 bg-slate-900 border-r border-slate-800 z-50 transform transition-all duration-300 -translate-x-full md:translate-x-0 overflow-y-auto no-scrollbar">
      <div class="flex flex-col h-full p-6 space-y-8">
        <div>
          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-purple-500 mb-6 flex items-center">
            <i class="fas fa-sliders mr-2"></i> Catalog Filters
          </h3>
          
          <div class="space-y-6">
            <div class="space-y-2">
              <label class="text-[10px] font-black uppercase tracking-widest text-slate-500 ml-1">Live Search</label>
              <div class="relative">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-xs"></i>
                <input type="text" id="search" placeholder="Enter keywords..." class="input-modern w-full pl-10 text-sm">
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-[10px] font-black uppercase tracking-widest text-slate-500 ml-1">Category</label>
              <select id="category" class="input-modern w-full text-sm appearance-none cursor-pointer">
                <option value="">All Categories</option>
                <option value="tools">🔧 Tools & Hardware</option>
                <option value="materials">🏗️ Core Materials</option>
                <option value="equipment">⚙️ Heavy Equipment</option>
                <option value="roofing">🏠 Roofing Solutions</option>
              </select>
            </div>

            <div id="subcategory-section" class="space-y-2 hidden">
              <label class="text-[10px] font-black uppercase tracking-widest text-slate-500 ml-1">Refine By</label>
              <select id="subcategory" class="input-modern w-full text-sm appearance-none cursor-pointer">
                <option value="">All Subcategories</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Promotional Card -->
        <div class="card-modern p-5 bg-gradient-to-br from-purple-900/20 to-indigo-900/20 border-purple-500/10">
           <div class="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center text-purple-400 mb-4">
             <i class="fas fa-shield-check"></i>
           </div>
           <h4 class="text-sm font-bold text-white mb-2">Verified Suppliers</h4>
           <p class="text-[10px] text-slate-400 leading-relaxed uppercase tracking-tighter font-black">All materials listed are quality-checked and come with site delivery options across the region.</p>
        </div>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 p-4 md:p-8 overflow-y-auto">
      <div class="space-y-8">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
          <div>
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-2 tracking-tight">Material <span class="text-purple-500">Catalog</span></h2>
            <p class="text-slate-400 font-medium">Browse verified construction essentials for your current sites.</p>
          </div>
          <div class="flex items-center space-x-2 text-[10px] font-black uppercase tracking-widest text-slate-500">
             <span id="results-count" class="text-purple-400"><%= items.length %></span> Items Found
          </div>
        </div>

        <!-- Items Grid -->
        <div id="items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-6 pb-12">
          <% items.forEach(item=> { %>
            <div class="card-modern group flex flex-col h-full"
              data-name="<%= item.name %>" data-description="<%= item.description || '' %>"
              data-category="<%= item.category || '' %>" data-subcategory="<%= item.sub_category || '' %>">
              
              <!-- Image Container -->
              <div class="relative aspect-[4/3] overflow-hidden rounded-t-2xl">
                <img src="<%= item.media_url || '/images/logo.png' %>" alt="<%= item.name %>"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                   <span class="text-[10px] font-black text-white uppercase tracking-widest">Quality Inspected</span>
                </div>
                <div class="absolute top-3 right-3">
                   <span class="bg-slate-900/60 backdrop-blur-md text-[10px] font-black text-purple-400 px-2.5 py-1 rounded-lg border border-purple-500/20 uppercase tracking-tighter">
                     <%= item.category || 'General' %>
                   </span>
                </div>
              </div>

              <!-- Content -->
              <div class="p-6 flex flex-col flex-grow">
                <h4 class="text-xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">
                  <%= item.name %>
                </h4>
                <p class="text-slate-400 text-xs mb-6 line-clamp-2 leading-relaxed flex-grow uppercase tracking-tight font-medium">
                  <%= item.description || 'High-performance construction supply for mission-critical engineering.' %>
                </p>
                
                <div class="flex items-center justify-between mt-auto pt-6 border-t border-slate-700/30">
                  <div class="flex flex-col">
                    <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-0.5">Unit Price</span>
                    <span class="text-lg font-bold text-white">KES <%= parseFloat(item.price).toLocaleString() %></span>
                  </div>
                  <button data-id="<%= item.id %>"
                    class="add-to-cart-btn h-12 w-12 bg-purple-600 hover:bg-purple-500 text-white rounded-xl transition-all btn-glow flex items-center justify-center shadow-lg shadow-purple-600/20">
                    <i class="fas fa-plus"></i>
                  </button>
                </div>
              </div>
            </div>
            <% }) %>
        </div>

        <!-- Empty State (Hidden by default) -->
        <div id="no-results" class="hidden py-20 text-center card-modern border-dashed">
           <i class="fas fa-magnifying-glass text-4xl text-slate-700 mb-4 opacity-30"></i>
           <h3 class="text-xl font-bold text-white mb-2">No matches found</h3>
           <p class="text-slate-500">Try adjusting your filters or search keywords.</p>
        </div>
      </div>
    </main>
  </div>

  <!-- FOOTER -->
  <%- include('partials/footer') %>

  <script src="/javascript/toast.js"></script>
</body>

</html>

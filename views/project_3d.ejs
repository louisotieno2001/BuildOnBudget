<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>3D - <%= project.name %> - BuildOnBudget</title>
  <link href="/output.css" rel="stylesheet" />
  <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r152/three.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/three@0.152.0/examples/js/loaders/GLTFLoader.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/three@0.152.0/examples/js/controls/OrbitControls.js"></script>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0f172a;
      color: #e2e8f0;
      height: 100vh;
      overflow: hidden;
    }
    #app {
      display: flex;
      flex-direction: column;
      height: 100vh;
    }
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 20px;
      background: rgba(15,23,42,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(51,65,85,0.5);
      z-index: 10;
      flex-shrink: 0;
    }
    header .brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    header .brand img { width: 28px; height: 28px; }
    header .brand span {
      font-size: 16px;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    header .brand span .hl { color: #a78bfa; }
    header .badge {
      font-size: 9px;
      font-weight: 900;
      letter-spacing: 0.15em;
      color: #a78bfa;
      background: rgba(139,92,246,0.12);
      padding: 4px 12px;
      border-radius: 999px;
    }
    header .actions { display: flex; gap: 8px; }
    header .actions a, header .actions button {
      background: rgba(51,65,85,0.4);
      border: 1px solid rgba(51,65,85,0.5);
      color: #cbd5e1;
      padding: 6px 14px;
      border-radius: 10px;
      font-size: 12px;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    header .actions a:hover, header .actions button:hover {
      background: rgba(139,92,246,0.2);
      border-color: rgba(139,92,246,0.4);
      color: #fff;
    }
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 0;
      flex: 1;
      min-height: 0;
    }
    @media (max-width: 900px) {
      .main-grid { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }
    #viewer-container {
      position: relative;
      background: #020617;
      overflow: hidden;
    }
    #viewer-container canvas { display: block; }
    .viewer-overlay {
      position: absolute;
      bottom: 16px;
      left: 16px;
      right: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      pointer-events: none;
      background: linear-gradient(to top, rgba(2,6,23,0.85), transparent);
      padding: 20px 16px 12px;
    }
    .status-dot {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #22c55e;
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .controls-hints {
      display: flex;
      gap: 16px;
      font-size: 9px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: rgba(148,163,184,0.6);
    }
    .controls-hints span { display: flex; align-items: center; gap: 4px; }
    .controls-hints i { font-size: 10px; }

    .sidebar {
      display: flex;
      flex-direction: column;
      border-left: 1px solid rgba(51,65,85,0.4);
      background: rgba(15,23,42,0.6);
      overflow-y: auto;
    }
    .panel {
      padding: 16px 20px;
      border-bottom: 1px solid rgba(51,65,85,0.3);
    }
    .panel:last-child { border-bottom: none; }
    .panel-title {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #64748b;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .panel-title i { font-size: 12px; color: #a78bfa; }
    .progress-track {
      width: 100%;
      height: 6px;
      background: #1e293b;
      border-radius: 999px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #7c3aed, #ec4899);
      border-radius: 999px;
      transition: width 0.6s ease;
    }
    .progress-label {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: #94a3b8;
      margin-top: 6px;
    }
    .upload-zone {
      border: 2px dashed rgba(51,65,85,0.6);
      border-radius: 14px;
      padding: 24px 16px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: rgba(30,41,59,0.3);
    }
    .upload-zone:hover { border-color: rgba(139,92,246,0.5); background: rgba(30,41,59,0.6); }
    .upload-zone i { font-size: 24px; color: #475569; margin-bottom: 8px; }
    .upload-zone p { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; }
    .upload-zone input { display: none; }

    .btn-primary {
      width: 100%;
      padding: 10px;
      background: #7c3aed;
      border: none;
      border-radius: 10px;
      color: #fff;
      font-weight: 700;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .btn-primary:hover { background: #6d28d9; box-shadow: 0 0 20px rgba(124,58,237,0.3); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

    .error-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: rgba(2,6,23,0.9);
      color: #94a3b8;
      gap: 12px;
      padding: 24px;
      text-align: center;
    }
    .error-overlay i { font-size: 40px; color: #ef4444; opacity: 0.6; }
    .error-overlay h3 { font-size: 16px; font-weight: 700; color: #e2e8f0; }
    .error-overlay p { font-size: 13px; max-width: 300px; line-height: 1.5; }
    .error-overlay button {
      margin-top: 8px;
      padding: 8px 24px;
      background: #334155;
      border: none;
      border-radius: 8px;
      color: #fff;
      font-weight: 600;
      cursor: pointer;
    }
    .error-overlay button:hover { background: #475569; }
  </style>
</head>
<body>
  <div id="app">
    <header>
      <div class="brand">
        <img src="/images/logo.png" alt="Bob">
        <span>BUILDON<span class="hl">BUDGET</span></span>
      </div>
      <span class="badge"><i class="fas fa-cube"></i>&ensp;3D</span>
      <div class="actions">
        <a href="/dashboard/<%= project.id %>"><i class="fas fa-arrow-left"></i> Back</a>
        <button id="reset-btn"><i class="fas fa-arrows-rotate"></i> Reset</button>
      </div>
    </header>

    <div class="main-grid">
      <div id="viewer-container">
        <div class="viewer-overlay">
          <div style="display:flex;align-items:center;gap:10px;">
            <span class="status-dot"></span>
            <span id="status-badge" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#94a3b8;">Ready</span>
          </div>
          <div class="controls-hints">
            <span><i class="fas fa-mouse"></i> Rotate</span>
            <span><i class="fas fa-mouse-pointer"></i> Pan</span>
            <span><i class="fas fa-arrows-up-down"></i> Zoom</span>
          </div>
        </div>
      </div>

      <div class="sidebar">
        <div class="panel">
          <div class="panel-title"><i class="fas fa-microchip"></i> Engine</div>
          <div class="progress-track">
            <div id="progress-bar" class="progress-fill" style="width:0%"></div>
          </div>
          <div class="progress-label">
            <span id="progress-text">0%</span>
            <span id="status-detail" style="color:#64748b;">Idle</span>
          </div>
        </div>

        <div class="panel">
          <div class="panel-title"><i class="fas fa-cloud-arrow-up"></i> Upload</div>
          <form id="upload-form">
            <div class="upload-zone" id="upload-zone">
              <i class="fas fa-file-pdf"></i>
              <p>BOQ &bull; Plans &bull; Photos</p>
            </div>
            <input type="file" id="docs-upload" multiple accept=".pdf,image/*,.dwg,.dxf" />
            <div style="height:10px"></div>
            <button type="submit" id="upload-btn" class="btn-primary">
              <i class="fas fa-wand-magic-sparkles"></i> Process
            </button>
          </form>
        </div>

        <div class="panel">
          <div class="panel-title"><i class="fas fa-sliders"></i> Settings</div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <label style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(30,41,59,0.4);border-radius:10px;font-size:12px;font-weight:500;cursor:pointer;">
              <span><i class="fas fa-sun" style="color:#a78bfa;margin-right:8px;"></i> Shadows</span>
              <input type="checkbox" id="toggle-shadows" checked style="accent-color:#7c3aed;">
            </label>
            <label style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(30,41,59,0.4);border-radius:10px;font-size:12px;font-weight:500;cursor:pointer;">
              <span><i class="fas fa-border-all" style="color:#a78bfa;margin-right:8px;"></i> Wireframe</span>
              <input type="checkbox" id="toggle-wireframe" style="accent-color:#7c3aed;">
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const projectId = '<%= project.id %>';

    // ── WebGL Detection ──
    function webglSupported() {
      try {
        const c = document.createElement('canvas');
        return !!(c.getContext('webgl') || c.getContext('webgl2'));
      } catch { return false; }
    }

    // ── Scene Setup ──
    const container = document.getElementById('viewer-container');
    let scene, camera, renderer, controls;
    let modelUrl = null;
    let animId = null;
    let pollInterval = null;

    function init3D() {
      if (!webglSupported()) {
        showError('WebGL not supported', 'Your browser does not support WebGL. Try a modern browser like Chrome or Firefox.');
        return;
      }

      const w = container.clientWidth;
      const h = container.clientHeight;
      if (w === 0 || h === 0) { requestAnimationFrame(init3D); return; }

      scene = new THREE.Scene();
      scene.background = new THREE.Color(0x020617);

      camera = new THREE.PerspectiveCamera(60, w / h, 0.1, 1000);
      camera.position.set(6, 5, 8);

      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false, powerPreference: 'high-performance' });
      renderer.setSize(w, h);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;
      renderer.debug.checkShaderErrors = false;
      container.appendChild(renderer.domElement);

      // context loss
      renderer.domElement.addEventListener('webglcontextlost', (e) => {
        e.preventDefault();
        showError('WebGL Context Lost', 'The 3D context was lost. Refresh to recover.');
      });
      renderer.domElement.addEventListener('webglcontextrestored', () => {
        location.reload();
      });

      // Lights
      const ambient = new THREE.AmbientLight(0xffffff, 0.6);
      scene.add(ambient);

      const key = new THREE.DirectionalLight(0xffffff, 1.2);
      key.position.set(5, 12, 8);
      key.castShadow = true;
      key.shadow.mapSize.set(1024, 1024);
      scene.add(key);

      const fill = new THREE.DirectionalLight(0x8b5cf6, 0.4);
      fill.position.set(-5, 3, -5);
      scene.add(fill);

      const rim = new THREE.DirectionalLight(0x60a5fa, 0.3);
      rim.position.set(0, -3, 10);
      scene.add(rim);

      // Placeholder scene
      buildPlaceholder();

      controls = new THREE.OrbitControls(camera, renderer.domElement);
      controls.enableDamping = true;
      controls.dampingFactor = 0.08;
      controls.minDistance = 3;
      controls.maxDistance = 30;
      controls.target.set(0, 1, 0);

      animate();
    }

    function buildPlaceholder() {
      // Ground plane
      const ground = new THREE.Mesh(
        new THREE.PlaneGeometry(16, 16),
        new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.9, metalness: 0 })
      );
      ground.rotation.x = -Math.PI / 2;
      ground.position.y = -1;
      ground.receiveShadow = true;
      scene.add(ground);

      // Grid helper (subtle)
      const grid = new THREE.GridHelper(16, 16, 0x334155, 0x1e293b);
      grid.position.y = -0.99;
      scene.add(grid);

      // House body
      const body = new THREE.Mesh(
        new THREE.BoxGeometry(3, 2, 3),
        new THREE.MeshStandardMaterial({ color: 0x334155, roughness: 0.3, metalness: 0.1 })
      );
      body.position.y = 0;
      body.castShadow = true;
      body.receiveShadow = true;
      scene.add(body);

      // Roof
      const roof = new THREE.Mesh(
        new THREE.ConeGeometry(2.8, 1.8, 4),
        new THREE.MeshStandardMaterial({ color: 0x6d28d9, roughness: 0.4, metalness: 0.2 })
      );
      roof.position.y = 1.9;
      roof.rotation.y = Math.PI / 4;
      roof.castShadow = true;
      scene.add(roof);
    }

    function animate() {
      animId = requestAnimationFrame(animate);
      controls.update();
      renderer.render(scene, camera);
    }

    // ── Model Loading ──
    const loader = new THREE.GLTFLoader();

    function loadModel(url) {
      setStatus('Loading...');
      loader.load(url, (gltf) => {
        clearScene();
        buildLights();

        const model = gltf.scene;
        model.traverse((child) => {
          if (child.isMesh) { child.castShadow = true; child.receiveShadow = true; }
        });

        const box = new THREE.Box3().setFromObject(model);
        const size = box.getSize(new THREE.Vector3());
        const maxDim = Math.max(size.x, size.y, size.z);
        if (maxDim > 5) model.scale.multiplyScalar(5 / maxDim);

        const center = box.getCenter(new THREE.Vector3());
        model.position.sub(center);
        model.position.y += 0.5;

        scene.add(model);
        setStatus('Ready');
      }, undefined, (err) => {
        console.error('Load error', err);
        setStatus('Error');
      });
    }

    function clearScene() {
      while (scene.children.length > 0) {
        const c = scene.children[0];
        scene.remove(c);
        if (c.geometry) c.geometry.dispose();
        if (c.material) c.material.dispose();
      }
    }

    function buildLights() {
      scene.add(new THREE.AmbientLight(0xffffff, 0.6));
      const k = new THREE.DirectionalLight(0xffffff, 1.2);
      k.position.set(5, 12, 8);
      k.castShadow = true;
      scene.add(k);
      const f = new THREE.DirectionalLight(0x8b5cf6, 0.4);
      f.position.set(-5, 3, -5);
      scene.add(f);
      const r = new THREE.DirectionalLight(0x60a5fa, 0.3);
      r.position.set(0, -3, 10);
      scene.add(r);
    }

    // ── UI Helpers ──
    function setStatus(text) {
      const el = document.getElementById('status-badge');
      if (el) el.textContent = text;
    }

    function showError(title, msg) {
      const existing = container.querySelector('.error-overlay');
      if (existing) return;
      const overlay = document.createElement('div');
      overlay.className = 'error-overlay';
      overlay.innerHTML = `<i class="fas fa-exclamation-triangle"></i><h3>${title}</h3><p>${msg}</p><button onclick="location.reload()">Refresh</button>`;
      container.appendChild(overlay);
    }

    // ── Polling ──
    async function pollModel() {
      try {
        const res = await fetch(`/projects/${projectId}/3d-model`);
        const data = await res.json();

        const sb = document.getElementById('status-badge');
        const sd = document.getElementById('status-detail');
        const pb = document.getElementById('progress-bar');
        const pt = document.getElementById('progress-text');

        if (sb) sb.textContent = data.status || 'Ready';
        if (sd) sd.textContent = data.message || 'Synchronized';
        const prog = data.progress || 0;
        if (pt) pt.textContent = prog + '%';
        if (pb) pb.style.width = prog + '%';

        if (data.modelUrl && data.modelUrl !== modelUrl) {
          modelUrl = data.modelUrl;
          loadModel(modelUrl);
        }
      } catch (err) {
        console.error('Poll error', err);
      }
    }

    // ── Events ──
    document.getElementById('upload-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const files = document.getElementById('docs-upload').files;
      if (files.length === 0) return;

      const btn = document.getElementById('upload-btn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

      setStatus('Uploading...');
      try {
        const fd = new FormData();
        for (const f of files) fd.append('docs', f);
        await fetch(`/projects/${projectId}/docs`, { method: 'POST', body: fd });
        setStatus('Processing...');
        setTimeout(pollModel, 2000);
      } catch { setStatus('Upload Failed'); }
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i> Process';
    });

    document.getElementById('upload-zone').onclick = () => document.getElementById('docs-upload').click();

    document.getElementById('reset-btn').onclick = () => {
      if (controls) { controls.reset(); camera.position.set(6, 5, 8); }
    };

    document.getElementById('toggle-shadows').onchange = function() {
      if (renderer) renderer.shadowMap.enabled = this.checked;
    };

    document.getElementById('toggle-wireframe').onchange = function() {
      scene.traverse((child) => {
        if (child.isMesh && child.material) {
          if (Array.isArray(child.material)) {
            child.material.forEach(m => m.wireframe = this.checked);
          } else {
            child.material.wireframe = this.checked;
          }
        }
      });
    };

    // ── Boot ──
    window.addEventListener('load', () => {
      init3D();
      pollModel();
      pollInterval = setInterval(pollModel, 5000);
    });

    window.addEventListener('resize', () => {
      if (!camera || !renderer) return;
      const w = container.clientWidth;
      const h = container.clientHeight;
      if (w === 0 || h === 0) return;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });

    window.addEventListener('beforeunload', () => {
      if (animId) cancelAnimationFrame(animId);
      if (pollInterval) clearInterval(pollInterval);
      if (renderer) { renderer.dispose(); container.removeChild(renderer.domElement); }
    });
  </script>
</body>
</html>
